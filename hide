  local new_secret
  new_secret=$("$MTG_BIN" generate-secret --hex "$new_sni" 2>/dev/null | tr -d '\n')
  if [[ -z "$new_secret" ]]; then
    local rh; rh=$(openssl rand -hex 16)
    local dh; dh=$(echo -n "$new_sni" | xxd -p | tr -d '\n')
    new_secret="ee${rh}${dh}"
  fi
  SNI_DOMAINS_ARR[$idx]="$new_sni"
  MTG_SECRETS_ARR[$idx]="$new_secret"
  local new_sni_str; new_sni_str=$(IFS='|'; echo "${SNI_DOMAINS_ARR[*]}")
  local new_sec_str; new_sec_str=$(IFS='|'; echo "${MTG_SECRETS_ARR[*]}")
  sed -i "s|SNI_DOMAINS=.*|SNI_DOMAINS=\"$new_sni_str\"|" "$CONFIG_FILE"
  sed -i "s|MTG_SECRETS=.*|MTG_SECRETS=\"$new_sec_str\"|" "$CONFIG_FILE"
  sed -i "s|MTG_SECRET=.*|MTG_SECRET=\"${MTG_SECRETS_ARR[0]}\"|" "$CONFIG_FILE"
  sed -i "s|^secret = .*|secret = \"$new_secret\"|" "$HIDE_DIR/config/mtg${idx}.toml"
  echo -e "  ${G}✓${N}  [$((idx+1))] $new_sni"
}

_mf_add_instance() {
  load_arrays
  local count=${#SNI_DOMAINS_ARR[@]}
  if [[ $count -ge 5 ]]; then
    echo -e "\n  ${Y}⚠️  Максимум 5 инстансов${N}"; pause; return
  fi

  echo -e "\n  ${BOLD}➕ Добавить инстанс${N}\n"
  echo -e "  ${C}[1]${N}  microsoft.com"
  echo -e "  ${C}[2]${N}  avito.ru"
  echo -e "  ${C}[3]${N}  ozon.ru"
  echo -e "  ${C}[4]${N}  wildberries.ru"
  echo -e "  ${C}[5]${N}  sberbank.ru"
  echo -e "  ${C}[6]${N}  Свой домен"
  echo ""
  read -rp "  Выбор: " ch

  local new_sni
  case "$ch" in
    1) new_sni="microsoft.com" ;;
    2) new_sni="avito.ru" ;;
    3) new_sni="ozon.ru" ;;
    4) new_sni="wildberries.ru" ;;
    5) new_sni="sberbank.ru" ;;
    6) read -rp "  Домен: " new_sni; [[ -z "$new_sni" ]] && return ;;
    *) return ;;
  esac

  local idx=$count
  local new_port=$((2398 + idx))
  local new_prom=$((3129 + idx))

  local new_secret
  new_secret=$("$MTG_BIN" generate-secret --hex "$new_sni" 2>/dev/null | tr -d '\n')
  if [[ -z "$new_secret" ]]; then
    local rh; rh=$(openssl rand -hex 16)
    local dh; dh=$(echo -n "$new_sni" | xxd -p | tr -d '\n')
    new_secret="ee${rh}${dh}"
  fi

  cat > "$HIDE_DIR/config/mtg${idx}.toml" << EOF
secret = "$new_secret"
bind-to = "127.0.0.1:$new_port"

[network]
  dns = "https://cloudflare-dns.com/dns-query"

[defense.anti-replay]
enabled = true
max-size = "1mib"

[defense.doppelganger]
urls = ["https://$new_sni/"]

[stats.prometheus]
enabled = true
bind-to = "127.0.0.1:$new_prom"
http-path = "/metrics"
metric-prefix = "mtg"

[upstream]
prefer-ip = "prefer-ipv4"
EOF

  touch "$HIDE_DIR/logs/mtg${idx}.log" "$HIDE_DIR/logs/mtg${idx}-error.log"
  chown mtgproxy:mtgproxy "$HIDE_DIR/logs/mtg${idx}.log" \
    "$HIDE_DIR/logs/mtg${idx}-error.log" 2>/dev/null || true

  SNI_DOMAINS_ARR+=("$new_sni")
  MTG_SECRETS_ARR+=("$new_secret")
  MTG_PORTS_ARR+=("$new_port")
  MTG_PROM_PORTS_ARR+=("$new_prom")

  local new_sni_str; new_sni_str=$(IFS='|'; echo "${SNI_DOMAINS_ARR[*]}")
  local new_sec_str; new_sec_str=$(IFS='|'; echo "${MTG_SECRETS_ARR[*]}")
  local new_port_str; new_port_str=$(IFS='|'; echo "${MTG_PORTS_ARR[*]}")
  local new_prom_str; new_prom_str=$(IFS='|'; echo "${MTG_PROM_PORTS_ARR[*]}")
  sed -i "s|SNI_DOMAINS=.*|SNI_DOMAINS=\"$new_sni_str\"|" "$CONFIG_FILE"
  sed -i "s|MTG_SECRETS=.*|MTG_SECRETS=\"$new_sec_str\"|" "$CONFIG_FILE"
  sed -i "s|MTG_PORTS=.*|MTG_PORTS=\"$new_port_str\"|" "$CONFIG_FILE"
  sed -i "s|MTG_PROM_PORTS=.*|MTG_PROM_PORTS=\"$new_prom_str\"|" "$CONFIG_FILE"

  systemctl daemon-reload
  systemctl enable "hipr-mtg@${idx}" 2>/dev/null
  systemctl start "hipr-mtg@${idx}"
  sleep 2

  _rebuild_nginx_stream

  local tg="tg://proxy?server=${DOMAIN}&port=443&secret=${new_secret}"
  echo ""
  echo -e "  ${G}✅ Инстанс добавлен: ${C}$new_sni${N}"
  echo -e "  ${C}${tg}${N}"
  pause
}

_mf_remove_instance() {
  load_arrays
  local count=${#SNI_DOMAINS_ARR[@]}
  if [[ $count -le 1 ]]; then
    echo -e "\n  ${Y}⚠️  Нельзя удалить последний инстанс${N}"; pause; return
  fi

  echo -e "\n  ${BOLD}➖ Удалить инстанс${N}\n"
  for i in "${!SNI_DOMAINS_ARR[@]}"; do
    printf "  ${C}[%d]${N} %s\n" "$((i+1))" "${SNI_DOMAINS_ARR[$i]}"
  done
  echo ""; echo -e "  ${R}[0]${N} Назад"
  read -rp "  Номер: " num
  [[ ! "$num" =~ ^[0-9]+$ || "$num" == "0" ]] && return
  local idx=$((num-1))
  [[ $idx -lt 0 || $idx -ge $count ]] && return

  read -rp "  Удалить инстанс ${SNI_DOMAINS_ARR[$idx]}? [y/N]: " c
  [[ "${c,,}" != "y" ]] && return

  local svc; svc=$(mtg_svc $idx)
  systemctl stop "$svc" 2>/dev/null
  systemctl disable "$svc" 2>/dev/null

  unset 'SNI_DOMAINS_ARR[$idx]'
  unset 'MTG_SECRETS_ARR[$idx]'
  unset 'MTG_PORTS_ARR[$idx]'
  unset 'MTG_PROM_PORTS_ARR[$idx]'
  SNI_DOMAINS_ARR=("${SNI_DOMAINS_ARR[@]}")
  MTG_SECRETS_ARR=("${MTG_SECRETS_ARR[@]}")
  MTG_PORTS_ARR=("${MTG_PORTS_ARR[@]}")
  MTG_PROM_PORTS_ARR=("${MTG_PROM_PORTS_ARR[@]}")

  local s1; s1=$(IFS='|'; echo "${SNI_DOMAINS_ARR[*]}")
  local s2; s2=$(IFS='|'; echo "${MTG_SECRETS_ARR[*]}")
  local s3; s3=$(IFS='|'; echo "${MTG_PORTS_ARR[*]}")
  local s4; s4=$(IFS='|'; echo "${MTG_PROM_PORTS_ARR[*]}")
  sed -i "s|SNI_DOMAINS=.*|SNI_DOMAINS=\"$s1\"|" "$CONFIG_FILE"
  sed -i "s|MTG_SECRETS=.*|MTG_SECRETS=\"$s2\"|" "$CONFIG_FILE"
  sed -i "s|MTG_PORTS=.*|MTG_PORTS=\"$s3\"|" "$CONFIG_FILE"
  sed -i "s|MTG_PROM_PORTS=.*|MTG_PROM_PORTS=\"$s4\"|" "$CONFIG_FILE"
  sed -i "s|MTG_SECRET=.*|MTG_SECRET=\"${MTG_SECRETS_ARR[0]}\"|" "$CONFIG_FILE"

  _rebuild_nginx_stream
  echo -e "\n  ${G}✅ Инстанс удалён${N}"; pause
}

_rebuild_nginx_stream() {
  load_arrays
  local map=""
  for i in "${!SNI_DOMAINS_ARR[@]}"; do
    map="${map}        ${SNI_DOMAINS_ARR[$i]}   127.0.0.1:${MTG_PORTS_ARR[$i]};\n"
  done

  cat > /etc/nginx/snippets/hipr-stream.conf << EOF
stream {
    map \$ssl_preread_server_name \$hipr_backend {
$(echo -e "$map")        default         127.0.0.1:8443;
    }
    server {
        listen 443;
        listen [::]:443;
        proxy_pass            \$hipr_backend;
        ssl_preread           on;
        proxy_timeout         10m;
        proxy_connect_timeout 10s;
    }
}
EOF

  nginx -t 2>/dev/null && systemctl reload nginx \
    && echo -e "  ${G}✓${N}  nginx stream обновлён" \
    || echo -e "  ${R}✗${N}  Ошибка nginx"
}

_renew_cert() {
  load_cfg; load_arrays; echo ""
  local CERT_PATH="/etc/letsencrypt/live/${DOMAIN:-_}"
  local SSL_CONF="/etc/nginx/sites-available/hipr-ssl"
  local STREAM_CONF="/etc/nginx/snippets/hipr-stream.conf"

  echo -e "  ${Y}🔒 Получаем/обновляем сертификат для $DOMAIN...${N}\n"

  # Certbot — если сертификата нет, получаем новый; если есть — обновляем
  if [[ -f "$CERT_PATH/fullchain.pem" ]]; then
    certbot renew --force-renewal -d "${DOMAIN:-}" 2>&1 | tail -8
  else
    certbot certonly       --webroot -w /var/www/certbot       --non-interactive --agree-tos       --email "${LE_EMAIL:-admin@${DOMAIN:-localhost}}"       -d "${DOMAIN:-}" 2>&1 | tail -10
  fi

  if [[ ! -f "$CERT_PATH/fullchain.pem" ]]; then
    echo -e "  ${R}❌ Сертификат не получен — проверьте DNS и попробуйте снова${N}"
    pause; return
  fi
  echo -e "  ${G}✅ Сертификат OK${N}"

  # Создаём SSL server-блок если его нет
  if [[ ! -f "$SSL_CONF" ]]; then
    echo -e "  ${Y}→ Создаём nginx SSL блок...${N}"
    cat > "$SSL_CONF" << NGINXEOF
server {
    listen 127.0.0.1:8443 ssl http2;
    server_name ${DOMAIN};

    ssl_certificate     ${CERT_PATH}/fullchain.pem;
    ssl_certificate_key ${CERT_PATH}/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    root  /var/www/hipr;
    index index.html;

    add_header Server "nginx";
    add_header Strict-Transport-Security "max-age=63072000" always;
    add_header X-Content-Type-Options "nosniff" always;

    access_log /opt/hipr/logs/nginx-access.log;
    error_log  /opt/hipr/logs/nginx-error.log warn;

    location / {
        try_files \$uri \$uri/ =404;
    }

    error_page 404 /index.html;
}
NGINXEOF
    ln -sf "$SSL_CONF" /etc/nginx/sites-enabled/ 2>/dev/null || true
    echo -e "  ${G}✅ SSL блок создан${N}"
  fi

  # Добавляем Grafana location если нужно
  if [[ "${INSTALL_GRAFANA:-false}" == "true" && "${GRAFANA_MODE:-}" == "path" ]]; then
    if ! grep -q '/grafana/' "$SSL_CONF" 2>/dev/null; then
      echo -e "  ${Y}→ Добавляем Grafana location...${N}"
      sed -i 's|    location / {|    location ^~ /grafana/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {|' "$SSL_CONF" 2>/dev/null || true
      echo -e "  ${G}✅ Grafana location добавлен${N}"
    fi
  fi

  # Создаём stream SNI конфиг если нет
  if [[ ! -f "$STREAM_CONF" ]]; then
    echo -e "  ${Y}→ Создаём nginx stream конфиг...${N}"
    mkdir -p /etc/nginx/snippets
    {
      echo "stream {"
      echo "    map \$ssl_preread_server_name \$hipr_backend {"
      for i in "${!SNI_DOMAINS_ARR[@]}"; do
        echo "        ${SNI_DOMAINS_ARR[$i]}   127.0.0.1:${MTG_PORTS_ARR[$i]};"
      done
      echo "        default         127.0.0.1:8443;"
      echo "    }"
      echo "    server {"
      echo "        listen 443;"
      echo "        listen [::]:443;"
      echo "        proxy_pass            \$hipr_backend;"
      echo "        ssl_preread           on;"
      echo "        proxy_timeout         10m;"
      echo "        proxy_connect_timeout 10s;"
      echo "    }"
      echo "}"
    } > "$STREAM_CONF"
    grep -q 'hipr-stream.conf' /etc/nginx/nginx.conf ||       echo "include /etc/nginx/snippets/hipr-stream.conf;" >> /etc/nginx/nginx.conf
    echo -e "  ${G}✅ Stream конфиг создан${N}"
  fi

  # Перезапускаем nginx
  if nginx -t 2>/dev/null; then
    systemctl reload nginx 2>/dev/null
    echo -e "  ${G}✅ nginx перезагружен${N}"
  else
    echo -e "  ${R}❌ Ошибка в конфиге nginx — проверьте nginx -t${N}"
  fi

  echo -e "\n  ${G}✅ Готово${N}"; sleep 2
}

_fix_grafana_nginx() {
  load_cfg; clear
  echo -e "\n  ${BOLD}📈 Диагностика и починка nginx → Grafana${N}\n"

  # ── 1. Grafana установлена? ──────────────────────────────────────────────
  if ! systemctl is-enabled grafana-server &>/dev/null; then
    echo -e "  ${R}❌ grafana-server не установлен${N}"
    echo -e "  ${DIM}Запустите переустановку: hide → [9] → [1]${N}"
    pause; return
  fi

  if ! systemctl is-active --quiet grafana-server; then
    echo -e "  ${Y}⚠️  grafana-server остановлен — запускаем...${N}"
    systemctl start grafana-server; sleep 3
    if ! systemctl is-active --quiet grafana-server; then
      echo -e "  ${R}❌ Grafana не запускается${N}"
      journalctl -u grafana-server -n 10 --no-pager 2>/dev/null | sed 's/^/  /'
      pause; return
    fi
    echo -e "  ${G}✅ Grafana запущена${N}"
  else
    echo -e "  ${G}✅ grafana-server работает${N}"
  fi

  # ── 2. Порт 3000 слушается? ──────────────────────────────────────────────
  if ! ss -tlnp 2>/dev/null | grep -q ':3000'; then
    echo -e "  ${R}❌ Порт 3000 не слушается${N}"
    journalctl -u grafana-server -n 5 --no-pager 2>/dev/null | sed 's/^/  /'
    pause; return
  fi
  echo -e "  ${G}✅ Порт 3000 активен${N}"

  local gmode="${GRAFANA_MODE:-path}"
  local gurl="${GRAFANA_URL:-}"
  local gdomain="${GRAFANA_DOMAIN:-}"
  local SSL_CONF="/etc/nginx/sites-available/hipr-ssl"
  local CERT_PATH="/etc/letsencrypt/live/${DOMAIN:-_}"

  echo -e "\n  ${DIM}Режим: ${W}$gmode${N}  URL: ${W}${gurl:-не задан}${N}\n"

  if [[ "$gmode" == "path" ]]; then
    # Режим /grafana/ — вставляем location в hipr-ssl
    if [[ ! -f "$SSL_CONF" ]]; then
      echo -e "  ${R}❌ $SSL_CONF не найден — сначала получите TLS сертификат${N}"
      pause; return
    fi

    if grep -q 'location /grafana/' "$SSL_CONF" 2>/dev/null; then
      echo -e "  ${Y}⚠️  location /grafana/ уже есть${N}"
      grep -A8 'location /grafana/' "$SSL_CONF" | sed 's/^/    /'
      echo ""
      read -rp "  Перезаписать? [y/N]: " ow
      [[ "${ow,,}" != "y" ]] && { echo -e "\n  Отменено"; pause; return; }
      # Удаляем старый блок через sed
      sed -i '/# Grafana/,+8d' "$SSL_CONF" 2>/dev/null || true
      sed -i '/location \/grafana\//,/^[[:space:]]*\}/d' "$SSL_CONF" 2>/dev/null || true
    fi

    # Записываем nginx блок через printf — никаких heredoc с {} внутри функции
    local NGINX_BLOCK
    NGINX_BLOCK=$(printf '\n    # Grafana — proxy_pass без trailing slash\n    location /grafana/ {\n        proxy_pass http://127.0.0.1:3000;\n        proxy_set_header Host $host;\n        proxy_set_header X-Real-IP $remote_addr;\n        proxy_set_header X-Forwarded-Proto $scheme;\n        proxy_set_header X-Forwarded-Host $host;\n    }\n')

    # Вставляем перед последней строкой файла если это }
    local last_line; last_line=$(tail -1 "$SSL_CONF")
    if [[ "$last_line" == "}" ]]; then
      head -n -1 "$SSL_CONF" > /tmp/hipr-ssl-gf.conf
      printf '%s\n}\n' "$NGINX_BLOCK" >> /tmp/hipr-ssl-gf.conf
      mv /tmp/hipr-ssl-gf.conf "$SSL_CONF"
    else
      printf '%s\n' "$NGINX_BLOCK" >> "$SSL_CONF"
    fi
    echo -e "  ${G}✅ location /grafana/ добавлен${N}"

  else
    # Режим поддомена
    if [[ -z "$gdomain" ]]; then
      echo -e "  ${R}❌ GRAFANA_DOMAIN не задан${N}"
      read -rp "  Поддомен (напр. stat.${DOMAIN:-example.com}): " gdomain
      [[ -z "$gdomain" ]] && { echo "  Отменено"; pause; return; }
      sed -i "s|GRAFANA_DOMAIN=.*|GRAFANA_DOMAIN=\"$gdomain\"|" "$CONFIG_FILE" 2>/dev/null \
        || echo "GRAFANA_DOMAIN=\"$gdomain\"" >> "$CONFIG_FILE"
    fi

    # Пишем конфиг поддомена через printf
    printf 'server {\n    listen 127.0.0.1:8444 ssl http2;\n    server_name %s;\n\n    ssl_certificate     %s/fullchain.pem;\n    ssl_certificate_key %s/privkey.pem;\n    ssl_protocols       TLSv1.2 TLSv1.3;\n\n    location / {\n        proxy_pass         http://127.0.0.1:3000;\n        proxy_set_header   Host $host;\n        proxy_set_header   X-Real-IP $remote_addr;\n    }\n}\n' \
      "$gdomain" "$CERT_PATH" "$CERT_PATH" \
      > /etc/nginx/sites-available/hipr-grafana

    ln -sf /etc/nginx/sites-available/hipr-grafana /etc/nginx/sites-enabled/

    local stream_conf="/etc/nginx/snippets/hipr-stream.conf"
    if [[ -f "$stream_conf" ]]; then
      sed -i "/$gdomain/d" "$stream_conf"
      sed -i "s/        default         127.0.0.1:8443;/        $gdomain   127.0.0.1:8444;\n        default         127.0.0.1:8443;/" "$stream_conf"
    fi
    echo -e "  ${G}✅ Конфиг поддомена $gdomain создан${N}"
  fi

  # ── Проверяем и перезагружаем nginx ─────────────────────────────────────
  echo ""
  if nginx -t 2>/tmp/hipr-nginx-gf.log; then
    systemctl reload nginx
    echo -e "  ${G}✅ nginx перезагружен${N}\n"
    echo -e "  ${BOLD}Grafana доступна:${N}"
    if [[ "$gmode" == "path" ]]; then
      echo -e "  ${C}https://${DOMAIN}/grafana/${N}"
    else
      echo -e "  ${C}https://${gdomain}/${N}"
    fi
    local gpass; gpass=$(grep "^GRAFANA_PASS=" "$CONFIG_FILE" 2>/dev/null | cut -d'"' -f2)
    [[ -n "$gpass" ]] && echo -e "  ${DIM}Логин: admin / $gpass${N}"
  else
    echo -e "  ${R}❌ nginx -t упал:${N}"
    cat /tmp/hipr-nginx-gf.log | sed 's/^/    /'
    echo -e "\n  ${DIM}Исправьте вручную: $SSL_CONF${N}"
    echo -e "  ${DIM}Затем: nginx -t && systemctl reload nginx${N}"
  fi
  rm -f /tmp/hipr-nginx-gf.log
  pause
}

_switch_mode() {
  load_cfg
  echo ""
  if [[ "${MODE:-single}" == "single" ]]; then
    echo -e "  ${Y}⚠️  Переключение в Multi-fronting режим${N}"
    echo -e "  ${DIM}Будет создано 3 инстанса: microsoft.com, avito.ru, ozon.ru${N}"
