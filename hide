_copy_all_links() {
  load_arrays
  local all=""
  for i in "${!SNI_DOMAINS_ARR[@]}"; do
    local tg="tg://proxy?server=${DOMAIN}&port=443&secret=${MTG_SECRETS_ARR[$i]}"
    all="${all}${tg}\n"
  done
  echo -e "$all" | xclip -selection clipboard 2>/dev/null || \
    echo -e "$all" | xsel --clipboard 2>/dev/null || \
    { echo -e "\n${Y}Ссылки:${N}\n$all"; }
