_stats_full() {
  load_arrays; clear; echo -e "\n  ${BOLD}📊 Статистика прокси${N}\n"

  local total_active=0 total_tg=0 total_bytes=0
  local total_replays=0 total_fronting=0

  for i in "${!MTG_PROM_PORTS_ARR[@]}"; do
    local port="${MTG_PROM_PORTS_ARR[$i]}"
    local m; m=$(curl -sf --max-time 3 "http://127.0.0.1:${port}/metrics" 2>/dev/null)
    [[ -z "$m" ]] && continue
    total_active=$(( total_active + $(echo "$m" | grep '^mtg_client_connections{' | awk '{sum+=$2} END{print int(sum)}') ))
    total_tg=$(( total_tg + $(echo "$m" | grep '^mtg_telegram_connections{' | awk '{sum+=$2} END{print int(sum)}') ))
    total_replays=$(( total_replays + $(echo "$m" | grep '^mtg_replay_attacks ' | awk '{print int($2)}') ))
    total_fronting=$(( total_fronting + $(echo "$m" | grep '^mtg_domain_fronting ' | awk '{print int($2)}') ))
    local b; b=$(echo "$m" | grep '^mtg_telegram_traffic{' | awk '{sum+=$2} END{print int(sum)}')
    total_bytes=$(( total_bytes + b ))
  done

  local fmt_b; fmt_b=$(python3 -c "
b=$total_bytes
if b > 1073741824: print(f'{b/1073741824:.1f} GB')
elif b > 1048576: print(f'{b/1048576:.1f} MB')
elif b > 1024: print(f'{b/1024:.1f} KB')
else: print(f'{b} B')
" 2>/dev/null || echo "${total_bytes}B")

  printf "  🟢  %-32s ${Y}%s${N}\n"  "TCP-соединений всего:"   "$total_active"
  local estimated=$(( total_active > 0 ? (total_active + 3) / 4 : 0 ))
  printf "  👤  %-32s ${G}~%s${N}\n" "Оценка реальных юзеров:" "$estimated"
  printf "      ${DIM}%-32s${N}\n"   "(Telegram держит 3–8 TCP conn/юзер)"
  printf "  📡  %-32s ${Y}%s${N}\n"  "→ Telegram соединений:"  "$total_tg"
  printf "  📦  %-32s ${G}%s${N}\n"  "Трафик всего:"           "$fmt_b"
  printf "  🎭  %-32s ${C}%s${N}\n"  "FakeTLS handshakes:"     "$total_fronting"
  printf "  🛡️   %-32s ${R}%s${N}\n" "Replay/probing атак:"    "$total_replays"
  echo ""; pause
}

_stats_per_instance() {
  load_arrays; clear; echo -e "\n  ${BOLD}📈 Статистика по инстансам${N}\n"

  for i in "${!SNI_DOMAINS_ARR[@]}"; do
    local sni="${SNI_DOMAINS_ARR[$i]}"
    local port="${MTG_PROM_PORTS_ARR[$i]:-$((3129+i))}"
    local svc; svc=$(mtg_svc $i)
    local status; systemctl is-active --quiet "$svc" 2>/dev/null && status="${G}🟢${N}" || status="${R}🔴${N}"

    echo -e "  ${BOLD}[$((i+1))] ${C}$sni${N} $status"

    local m; m=$(curl -sf --max-time 2 "http://127.0.0.1:${port}/metrics" 2>/dev/null)
    if [[ -z "$m" ]]; then
      echo -e "  ${DIM}Prometheus недоступен (порт $port)${N}\n"
      continue
    fi

    local active tg bytes fronting replays
    active=$(echo "$m" | grep '^mtg_client_connections{' | awk '{sum+=$2} END{print int(sum)}')
    tg=$(echo "$m" | grep '^mtg_telegram_connections{' | awk '{sum+=$2} END{print int(sum)}')
    bytes=$(echo "$m" | grep '^mtg_telegram_traffic{' | awk '{sum+=$2} END{print int(sum)}')
    fronting=$(echo "$m" | grep '^mtg_domain_fronting ' | awk '{print int($2)}')
    replays=$(echo "$m" | grep '^mtg_replay_attacks ' | awk '{print int($2)}')
    local fmt_b; fmt_b=$(python3 -c "
b=${bytes:-0}
if b>1048576: print(f'{b/1048576:.1f}MB')
elif b>1024: print(f'{b/1024:.1f}KB')
else: print(f'{b}B')
" 2>/dev/null || echo "—")

    local est_users=$(( ${active:-0} > 0 ? (${active:-0} + 3) / 4 : 0 ))
    printf "  ${DIM}  ~юзер: ${G}%-3s${N}  ${DIM}conn: ${Y}%-4s${N}  ${DIM}TG: ${Y}%-4s${N}  ${DIM}Трафик: ${G}%-8s${N}  ${DIM}FakeTLS: ${C}%-6s${N}  ${DIM}Атак: ${R}%s${N}\n" \
      "$est_users" "${active:-0}" "${tg:-0}" "$fmt_b" "${fronting:-0}" "${replays:-0}"
    echo ""
  done
  pause
}

