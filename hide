# 7. ОБНОВЛЕНИЕ
# ══════════════════════════════════════════════════════════════════════════
menu_update() {
  clear; echo ""
  top_b
  printf "${B}  ║${N}  ${BOLD}%-55s${N}${B}║${N}\n" "Обновление"
  bot_b; echo ""
  echo -e "  ${W}[1]${N}  Обновить mtg до последней версии"
  echo -e "  ${W}[2]${N}  Обновить hide (CLI меню)"
  echo -e "  ${W}[3]${N}  Обновить пакеты системы"
  echo -e "  ${W}[4]${N}  Версии компонентов"
  echo ""; echo -e "  ${R}[0]${N}  Назад"; echo ""
  read -rp "  Выберите: " ch
  case "$ch" in
    1)
      echo -e "\n  ${Y}Обновляем mtg...${N}"
      local latest; latest=$(curl -sf --max-time 10 \
        "https://api.github.com/repos/9seconds/mtg/releases/latest" \
        | python3 -c "import sys,json; print(json.load(sys.stdin)['tag_name'].lstrip('v'))" 2>/dev/null || echo "")
      if [[ -n "$latest" ]]; then
        local arch; arch=$(uname -m)
        case "$arch" in x86_64) ma="amd64" ;; aarch64) ma="arm64" ;; *) ma="amd64" ;; esac
        local url="https://github.com/9seconds/mtg/releases/download/v${latest}/mtg-${latest}-linux-${ma}.tar.gz"
        wget -q "$url" -O /tmp/mtg_new.tar.gz 2>/dev/null && \
          tar -xzf /tmp/mtg_new.tar.gz -C /tmp/ && \
          find /tmp -name "mtg" -newer /tmp/mtg_new.tar.gz -type f | head -1 | xargs -I{} cp {} "$MTG_BIN" && \
          chmod +x "$MTG_BIN" && \
          systemctl restart hipr-mtg && \
          echo -e "  ${G}✓ mtg обновлён до v$latest${N}" || \
          echo -e "  ${R}✗ Ошибка обновления${N}"
        rm -f /tmp/mtg_new.tar.gz
      else
        echo -e "  ${Y}Не удалось получить версию${N}"
      fi
      sleep 2 ;;
    2)
      echo -e "\n  ${Y}Обновляем hide...${N}"
      curl -fsSL "https://raw.githubusercontent.com/ChernOvOne/HIPR/main/hide" \
        -o "$HIDE_BIN" && chmod +x "$HIDE_BIN" && \
        echo -e "  ${G}✓ hide обновлён${N}" || echo -e "  ${R}✗ Ошибка${N}"
      sleep 2 ;;
    3) apt-get update -qq && apt-get upgrade -y -qq 2>&1 | tail -5; sleep 2 ;;
    4)
      clear; echo ""
      printf "  %-20s %s\n" "HIPR:" "$VERSION"
      printf "  %-20s %s\n" "mtg:" "$($MTG_BIN --version 2>/dev/null | head -1 || echo '—')"
      printf "  %-20s %s\n" "nginx:" "$(nginx -v 2>&1 | grep -o '[0-9.]*' | head -1)"
      printf "  %-20s %s\n" "certbot:" "$(certbot --version 2>/dev/null | head -1 || echo '—')"
      printf "  %-20s %s\n" "OpenSSL:" "$(openssl version | awk '{print $2}')"
      echo ""; read -rp "  [Enter]" _ ;;
    0|q) return ;;
  esac
}

