collect_themes() {
  THEME_DIRS=(); THEME_NAMES=(); THEME_DESCS=()
  for base in "$THEMES_LOCAL" "$THEMES_LOCAL/custom"; do
    [[ -d "$base" ]] || continue
    for dir in "$base"/*/; do
      [[ -f "$dir/index.html" ]] || continue
      [[ "$(basename "$dir")" == "custom" ]] && continue
      local jf="$dir/theme.json"
      local name="" desc=""
      if [[ -f "$jf" ]]; then
        name=$(python3 -c "import json; d=json.load(open('$jf')); print(d.get('name',''))" 2>/dev/null || true)
        desc=$(python3 -c "import json; d=json.load(open('$jf')); print(d.get('preview', d.get('description','')))" 2>/dev/null || true)
      fi
      name="${name:-$(basename "$dir")}"; desc="${desc:-—}"
      THEME_DIRS+=("${dir%/}"); THEME_NAMES+=("$name"); THEME_DESCS+=("$desc")
    done
  done
}

themes_pick() {
  collect_themes
  if [[ ${#THEME_DIRS[@]} -eq 0 ]]; then
    echo -e "\n  ${Y}⚠️  Нет тем${N}"; pause; return
  fi
  clear; echo ""
  top_b
  printf "${B}  ║${N}  ${BOLD}✅ %-53s${N}${B}║${N}\n" "Выбор темы"
  sep; row ""
  local active; active=$(active_theme)
  for i in "${!THEME_DIRS[@]}"; do
    local mark=""; [[ "${THEME_NAMES[$i]}" == "$active" ]] && mark=" ${G}◀ активна${N}"
    printf "${B}  ║${N}  ${C}[%d]${N} ${BOLD}%-30s${N}%-16b${B}║${N}\n" \
      "$((i+1))" "${THEME_NAMES[$i]}" "$mark"
    printf "${B}  ║${N}      ${DIM}%-52s${N}${B}║${N}\n" "${THEME_DESCS[$i]}"
    row ""
  done
  bot_b; echo ""; echo -e "  ${R}[0]${N}  ← Назад"; echo ""
  read -rp "  Номер: " ch
  [[ "$ch" == "0" || "$ch" == "q" ]] && return
  [[ ! "$ch" =~ ^[0-9]+$ ]] && { echo -e "\n  ${R}Неверный номер${N}"; sleep 1; return; }
  local idx=$((ch-1))
  [[ $idx -ge 0 && $idx -lt ${#THEME_DIRS[@]} ]] \
    && themes_apply "${THEME_DIRS[$idx]}" "${THEME_NAMES[$idx]}" \
    || { echo -e "\n  ${R}Нет такой темы${N}"; sleep 1; }
}

themes_apply() {
  local src="$1" name="$2"
  echo ""; echo -e "  ${Y}🎨 Применяю тему: ${BOLD}$name${N}"
  if ls "$WEB_DIR"/*.html &>/dev/null 2>&1; then
    local bak="$THEMES_LOCAL/backup_$(date +%Y%m%d_%H%M%S)"
    mkdir -p "$bak"; cp -r "$WEB_DIR"/. "$bak/" 2>/dev/null
    echo -e "  ${DIM}💾 Бэкап: $bak${N}"
  fi
  rm -rf "${WEB_DIR:?}"/*
  cp -r "$src"/. "$WEB_DIR/"
  printf 'User-agent: *\nDisallow: /\n' > "$WEB_DIR/robots.txt"
  chown -R www-data:www-data "$WEB_DIR" 2>/dev/null || true
  echo "$name" > "$HIDE_DIR/config/active_theme"
  nginx -t 2>/dev/null && systemctl reload nginx \
    && echo -e "  ${G}✅ Тема «$name» активирована${N}" \
    || echo -e "  ${R}❌ Ошибка nginx${N}"
  pause
}

themes_github() {
  clear; echo -e "\n  ${BOLD}☁️  Темы на GitHub${N}\n"
  if ! curl -sf --max-time 5 https://api.github.com > /dev/null 2>&1; then
    echo -e "  ${R}❌ GitHub недоступен${N}"; pause; return
  fi
  local api_json; api_json=$(curl -sf --max-time 10 "$THEMES_API" 2>/dev/null || echo "[]")
  local dirs; dirs=$(echo "$api_json" | python3 -c "
import sys,json
try:
  for i in json.load(sys.stdin):
    if i.get('type')=='dir' and i['name'] not in ['backup','custom']:
      print(i['name'])
except: pass" 2>/dev/null || echo "blog
freelancer
coming-soon")
  local arr=(); while IFS= read -r t; do [[ -n "$t" ]] && arr+=("$t"); done <<< "$dirs"
  for i in "${!arr[@]}"; do
    local t="${arr[$i]}"
    local inst=""; [[ -d "$THEMES_LOCAL/$t" ]] && inst="${G}[установлена]${N}"
    printf "  ${C}[%d]${N} ${BOLD}%-22s${N} %-20b\n" "$((i+1))" "$t" "$inst"
  done
  echo -e "\n  ${C}[a]${N} 📥 Скачать все  ${R}[0]${N} Назад"; echo ""
  read -rp "  Выбор: " ch
  if [[ "$ch" == "a" || "$ch" == "A" ]]; then
    for t in "${arr[@]}"; do _dl_theme "$t"; done
  elif [[ "$ch" =~ ^[0-9]+$ ]]; then
    local idx=$((ch-1))
    [[ $idx -ge 0 && $idx -lt ${#arr[@]} ]] && _dl_theme "${arr[$idx]}"
  fi
  pause
}

_dl_theme() {
  local name="$1" dest="$THEMES_LOCAL/$name"
  echo -e "\n  ${Y}📥 Скачиваю: $name${N}"
  mkdir -p "$dest"
  for f in index.html theme.json about.html; do
    curl -sf --max-time 10 "$THEMES_RAW/$name/$f" -o "$dest/$f" 2>/dev/null \
      && echo -e "    ${G}✓${N} $f" || true
  done
  [[ -f "$dest/index.html" ]] \
    && echo -e "  ${G}✅ '$name' установлена${N}" \
    || { echo -e "  ${R}❌ index.html не найден${N}"; rm -rf "$dest"; }
}

themes_add() {
  clear; echo -e "\n  ${BOLD}📦 Добавить свою тему${N}\n"
  read -rp "  Путь к папке или .zip: " src; [[ -z "$src" ]] && return
  src="${src/#\~/$HOME}"
  if [[ -f "$src" && "$src" == *.zip ]]; then
    command -v unzip &>/dev/null || apt-get install -y -qq unzip 2>/dev/null
    local tmp; tmp=$(mktemp -d)
    unzip -q "$src" -d "$tmp"
    local idx_path; idx_path=$(find "$tmp" -name "index.html" | head -1)
    [[ -z "$idx_path" ]] && { echo -e "\n  ${R}❌ index.html не найден${N}"; rm -rf "$tmp"; sleep 2; return; }
    _install_theme "$(dirname "$idx_path")"; rm -rf "$tmp"
  elif [[ -d "$src" ]]; then
    [[ ! -f "$src/index.html" ]] && { echo -e "\n  ${R}❌ Нет index.html${N}"; sleep 2; return; }
    _install_theme "$src"
  else
    echo -e "\n  ${R}❌ Путь не найден${N}"; sleep 2
  fi
}

_install_theme() {
  local src="$1" name=""
  [[ -f "$src/theme.json" ]] && \
    name=$(python3 -c "import json; d=json.load(open('$src/theme.json')); print(d.get('name',''))" 2>/dev/null || true)
  [[ -z "$name" ]] && { read -rp "  Название: " name; [[ -z "$name" ]] && return; }
  local safe; safe=$(echo "$name" | tr ' ' '-' | tr -cd '[:alnum:]-_' | tr '[:upper:]' '[:lower:]')
  local dest="$THEMES_LOCAL/custom/$safe"
  mkdir -p "$(dirname "$dest")"; cp -r "$src" "$dest"
  echo -e "\n  ${G}✅ Тема «$name» добавлена${N}\n"
  read -rp "  Применить сейчас? [Y/n]: " ap
  [[ "${ap,,}" != "n" ]] && themes_apply "$dest" "$name"
}

themes_preview() {
  load_cfg; echo ""
  [[ -n "${DOMAIN:-}" ]] \
    && echo -e "  🌐  ${C}https://$DOMAIN${N}\n  ${DIM}Это видит ТСПУ при проверке${N}" \
    || echo -e "  ${Y}⚠️  Домен не настроен${N}"
  echo ""; pause
}

themes_delete() {
  collect_themes
  local cdirs=(); local cnames=()
  for i in "${!THEME_DIRS[@]}"; do
    [[ "${THEME_DIRS[$i]}" == *"/custom/"* ]] && \
      { cdirs+=("${THEME_DIRS[$i]}"); cnames+=("${THEME_NAMES[$i]}"); }
  done
  if [[ ${#cdirs[@]} -eq 0 ]]; then
    echo -e "\n  ${Y}⚠️  Нет пользовательских тем${N}"; pause; return
  fi
  clear; echo -e "\n  ${BOLD}🗑️  Удалить тему${N}\n"
  for i in "${!cdirs[@]}"; do printf "  ${C}[%d]${N} %s\n" "$((i+1))" "${cnames[$i]}"; done
  echo ""; echo -e "  ${R}[0]${N} Назад"; echo ""
  read -rp "  Номер: " ch
  [[ "$ch" == "0" || "$ch" == "q" || -z "$ch" ]] && return
  [[ ! "$ch" =~ ^[0-9]+$ ]] && return
  local idx=$((ch-1))
  if [[ $idx -ge 0 && $idx -lt ${#cdirs[@]} ]]; then
    read -rp "  Удалить «${cnames[$idx]}»? [y/N]: " c
    [[ "${c,,}" == "y" ]] && { rm -rf "${cdirs[$idx]}"; echo -e "  ${G}✅ Удалена${N}"; sleep 1; }
  fi
}

