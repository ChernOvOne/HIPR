      5) clear; echo ""; grep -v "^#" "$CONFIG_FILE" | grep -v "^$" | \
           while IFS='=' read -r k v; do printf "  ${C}%-18s${N} = ${W}%s${N}\n" "$k" "$v"; done
         echo ""; read -rp "  [Enter]" _ ;;
