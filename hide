# УВЕДОМЛЕНИЯ И БОТ
# ══════════════════════════════════════════════════════════════════════════
menu_notifications() {
  while true; do
    load_cfg; clear; echo ""
    top_b
    printf "${B}  ║${N}  ${BOLD}🔔 %-53s${N}${B}║${N}\n" "Уведомления и бот"
    sep
    kv "🤖 Бот:" "$( [[ -n "${BOT_TOKEN:-}" ]] && echo '✅ настроен' || echo '➖ не настроен' )"
    if [[ -n "${BOT_TOKEN:-}" ]]; then
      kv "💬 Chat ID:" "${BOT_CHAT_ID:-—}"
      # Дополнительные каналы
      local extra_count; extra_count=$(grep -c '^NOTIFY_EXTRA_' "$CONFIG_FILE" 2>/dev/null | tr -d '[:space:]' || echo 0)
      extra_count="${extra_count:-0}"
      [[ "${extra_count}" =~ ^[0-9]+$ && "${extra_count}" -gt 0 ]] && kv "➕ Доп. каналы:" "$extra_count"
    fi
    # Пороги уведомлений
    local alert_cpu; alert_cpu=$(grep '^ALERT_CPU=' "$CONFIG_FILE" 2>/dev/null | cut -d'"' -f2)
    local alert_ram; alert_ram=$(grep '^ALERT_RAM=' "$CONFIG_FILE" 2>/dev/null | cut -d'"' -f2)
    local alert_disk; alert_disk=$(grep '^ALERT_DISK=' "$CONFIG_FILE" 2>/dev/null | cut -d'"' -f2)
    kv "⚠️  CPU порог:" "${alert_cpu:-80}%"
    kv "⚠️  RAM порог:" "${alert_ram:-85}%"
    kv "⚠️  Диск порог:" "${alert_disk:-90}%"
    bot_b; echo ""

    echo -e "  ${C}[1]${N}  🤖  Настроить основной бот"
    echo -e "  ${C}[2]${N}  ➕  Добавить канал уведомлений"
    echo -e "  ${C}[3]${N}  📋  Список каналов"
    echo -e "  ${C}[4]${N}  ⚙️   Настройки порогов алертов"
    echo -e "  ${C}[5]${N}  📨  Отправить тестовое уведомление"
    echo -e "  ${C}[6]${N}  📊  Отправить отчёт сейчас"
    echo -e "  ${C}[7]${N}  🕐  Настроить расписание отчётов"
    echo ""; echo -e "  ${R}[0]${N}  ← Назад"; echo ""
    read -rp "  Выберите: " ch
    case "$ch" in
      1) _setup_bot ;;
      2) _add_notify_channel ;;
      3) _list_notify_channels ;;
      4) _setup_alert_thresholds ;;
      5) _send_test_notify ;;
      6) bash "$HIDE_DIR/bin/daily-report.sh" && echo -e "
  ${G}✅ Отчёт отправлен${N}"; sleep 2 ;;
      7) _setup_report_schedule ;;
      0|q) return ;;
    esac
  done
}

_add_notify_channel() {
  load_cfg; clear; echo ""
  echo -e "  ${BOLD}➕ Добавить канал уведомлений${N}\n"
  echo -e "  ${DIM}Уведомления будут дублироваться во все настроенные каналы${N}\n"
  read -rp "  Bot Token: " new_token
  [[ -z "$new_token" ]] && { echo "  Отменено."; sleep 1; return; }
  read -rp "  Chat ID: " new_chat
  [[ -z "$new_chat" ]] && { echo "  Отменено."; sleep 1; return; }
  read -rp "  Название канала (напр. 'Личный', 'Группа'): " ch_name
  ch_name="${ch_name:-Канал}"

  # Проверяем
  local test_res; test_res=$(curl -sf --max-time 5     "https://api.telegram.org/bot${new_token}/sendMessage"     -d "chat_id=${new_chat}" -d "text=✅ HIPR: канал ${ch_name} подключён" 2>/dev/null)
  if echo "$test_res" | grep -q '"ok":true'; then
    # Сохраняем как NOTIFY_EXTRA_N
    local idx; idx=$(grep -c '^NOTIFY_EXTRA_' "$CONFIG_FILE" 2>/dev/null || echo 0)
    echo "NOTIFY_EXTRA_${idx}="${new_token}|${new_chat}|${ch_name}"" >> "$CONFIG_FILE"
    echo -e "
  ${G}✅ Канал '${ch_name}' добавлен${N}"
  else
    echo -e "
  ${R}❌ Не удалось отправить тестовое сообщение — проверьте токен и chat_id${N}"
  fi
  sleep 2
}

_list_notify_channels() {
  load_cfg; clear; echo ""
  echo -e "  ${BOLD}📋 Каналы уведомлений${N}\n"
  if [[ -n "${BOT_TOKEN:-}" ]]; then
    echo -e "  ${G}[0]${N} Основной: chat_id=${BOT_CHAT_ID:-—}"
  fi
  local i=0
  while IFS= read -r line; do
    local token; token=$(echo "$line" | cut -d'|' -f1)
    local chat; chat=$(echo "$line" | cut -d'|' -f2)
    local name; name=$(echo "$line" | cut -d'|' -f3)
    ((i++))
    echo -e "  ${C}[$i]${N} ${name}: chat_id=${chat}"
  done < <(grep '^NOTIFY_EXTRA_' "$CONFIG_FILE" 2>/dev/null | cut -d'"' -f2)
  [[ $i -eq 0 && -z "${BOT_TOKEN:-}" ]] && echo -e "  ${DIM}Каналы не настроены${N}"
  echo ""; pause
}

_setup_alert_thresholds() {
  load_cfg; clear; echo ""
  echo -e "  ${BOLD}⚙️  Настройка порогов алертов${N}\n"
  echo -e "  ${DIM}При превышении порога watchdog отправит уведомление${N}\n"

  local cur_cpu; cur_cpu=$(grep '^ALERT_CPU=' "$CONFIG_FILE" 2>/dev/null | cut -d'"' -f2 || echo "80")
  local cur_ram; cur_ram=$(grep '^ALERT_RAM=' "$CONFIG_FILE" 2>/dev/null | cut -d'"' -f2 || echo "85")
  local cur_disk; cur_disk=$(grep '^ALERT_DISK=' "$CONFIG_FILE" 2>/dev/null | cut -d'"' -f2 || echo "90")

  read -rp "  CPU порог % [текущий: ${cur_cpu:-80}, Enter=пропустить]: " new_cpu
  read -rp "  RAM порог % [текущий: ${cur_ram:-85}, Enter=пропустить]: " new_ram
  read -rp "  Диск порог % [текущий: ${cur_disk:-90}, Enter=пропустить]: " new_disk

  [[ -n "$new_cpu" ]] && {
    grep -q '^ALERT_CPU=' "$CONFIG_FILE"       && sed -i "s/^ALERT_CPU=.*/ALERT_CPU="${new_cpu}"/" "$CONFIG_FILE"       || echo "ALERT_CPU="${new_cpu}"" >> "$CONFIG_FILE"
  }
  [[ -n "$new_ram" ]] && {
    grep -q '^ALERT_RAM=' "$CONFIG_FILE"       && sed -i "s/^ALERT_RAM=.*/ALERT_RAM="${new_ram}"/" "$CONFIG_FILE"       || echo "ALERT_RAM="${new_ram}"" >> "$CONFIG_FILE"
  }
  [[ -n "$new_disk" ]] && {
    grep -q '^ALERT_DISK=' "$CONFIG_FILE"       && sed -i "s/^ALERT_DISK=.*/ALERT_DISK="${new_disk}"/" "$CONFIG_FILE"       || echo "ALERT_DISK="${new_disk}"" >> "$CONFIG_FILE"
  }
  echo -e "
  ${G}✅ Пороги сохранены${N}"; sleep 2
}

_send_test_notify() {
  load_cfg; echo ""
  local msg="🧪 <b>HIPR тест</b>

✅ Уведомления работают!
🌐 Домен: ${DOMAIN}
📡 DC: ${ACTIVE_DC}
⏱️ Время: $(date '+%d.%m.%Y %H:%M:%S')"

  local sent=0
  # Основной канал
  if [[ -n "${BOT_TOKEN:-}" && -n "${BOT_CHAT_ID:-}" ]]; then
    curl -s --max-time 10       "https://api.telegram.org/bot${BOT_TOKEN}/sendMessage"       -d "chat_id=${BOT_CHAT_ID}"       --data-urlencode "text=${msg}"       -d "parse_mode=HTML" > /dev/null 2>&1 && ((sent++))
  fi
  # Дополнительные каналы
  while IFS= read -r line; do
    local token; token=$(echo "$line" | cut -d'|' -f1)
    local chat; chat=$(echo "$line" | cut -d'|' -f2)
    curl -s --max-time 10       "https://api.telegram.org/bot${token}/sendMessage"       -d "chat_id=${chat}"       --data-urlencode "text=${msg}"       -d "parse_mode=HTML" > /dev/null 2>&1 && ((sent++))
  done < <(grep '^NOTIFY_EXTRA_' "$CONFIG_FILE" 2>/dev/null | cut -d'"' -f2)

  if [[ "$sent" -gt 0 ]]; then
    echo -e "  ${G}✅ Тест отправлен в $sent канал(ов)${N}"
  else
    echo -e "  ${R}❌ Не удалось отправить — проверьте настройки бота${N}"
  fi
  sleep 2
}

_setup_report_schedule() {
  load_cfg; clear; echo ""
  echo -e "  ${BOLD}🕐 Расписание ежедневных отчётов${N}\n"
  local cur_hour; cur_hour=$(crontab -l 2>/dev/null | grep 'daily-report' | awk '{print $2}')
  echo -e "  Текущее время отправки: ${W}${cur_hour:-17}:00 UTC${N} (≈ 20:00 МСК)\n"
  echo -e "  ${C}[1]${N}  9:00 UTC  (12:00 МСК)"
  echo -e "  ${C}[2]${N}  15:00 UTC  (18:00 МСК)"
  echo -e "  ${C}[3]${N}  17:00 UTC  (20:00 МСК)  ${DIM}(текущее)${N}"
  echo -e "  ${C}[4]${N}  21:00 UTC  (00:00 МСК)"
  echo -e "  ${C}[5]${N}  Своё время"
  echo -e "  ${C}[6]${N}  Отключить отчёты"
  echo ""; read -rp "  Выбор [1-6]: " ch
  local hour=""
  case "$ch" in
    1) hour=9 ;;  2) hour=15 ;; 3) hour=17 ;; 4) hour=21 ;;
    5) read -rp "  Час UTC (0-23): " hour ;;
    6) crontab -l 2>/dev/null | grep -v 'daily-report' | crontab - 2>/dev/null
       echo -e "
  ${G}✅ Отчёты отключены${N}"; sleep 2; return ;;
  esac
  if [[ -n "$hour" ]]; then
    (crontab -l 2>/dev/null | grep -v 'daily-report'
     echo "0 ${hour} * * * $HIDE_DIR/bin/daily-report.sh") | crontab -
    echo -e "
  ${G}✅ Отчёты будут отправляться в ${hour}:00 UTC${N}"
    sleep 2
  fi
}

_setup_bot() {
  clear; echo -e "\n  ${BOLD}🤖 Настройка Telegram-бота${N}\n"
  echo -e "  1. Откройте @BotFather в Telegram"
  echo -e "  2. /newbot → скопируйте токен"
  echo -e "  3. Напишите боту /start"
  echo -e "  4. Узнайте chat_id: ${C}api.telegram.org/bot<TOKEN>/getUpdates${N}\n"
  read -rp "  Bot Token: " tok; [[ -z "$tok" ]] && return
  read -rp "  Chat ID: " cid; [[ -z "$cid" ]] && return
  if curl -sf --max-time 10 \
    "https://api.telegram.org/bot${tok}/sendMessage" \
    -d "chat_id=${cid}&text=✅ HIPR бот подключён!" > /dev/null 2>&1; then
    sed -i "s|BOT_TOKEN=.*|BOT_TOKEN=\"$tok\"|" "$CONFIG_FILE"
    sed -i "s|BOT_CHAT_ID=.*|BOT_CHAT_ID=\"$cid\"|" "$CONFIG_FILE"
    echo -e "\n  ${G}✅ Бот настроен — проверьте сообщение${N}"
  else
    echo -e "\n  ${R}❌ Ошибка — проверьте токен и chat_id${N}"
  fi
  sleep 3
}

