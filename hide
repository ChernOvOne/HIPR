    load_cfg
    echo -e "hipr-mtg:  $(svc hipr-mtg)"
    echo -e "nginx:     $(svc nginx)"
    echo -e "watchdog:  $(svc hipr-watchdog.timer 2>/dev/null || echo '—')"
    echo -e "Домен:     ${DOMAIN:-—}"
    echo -e "DC:        ${ACTIVE_DC:-—}"
    echo -e "Тема:      $(active_theme)" ;;
  logs)     tail -f "$LOG_MTG" 2>/dev/null ;;
  restart)  systemctl restart hipr-mtg nginx; echo -e "${G}✓${N}" ;;
  stop)     systemctl stop hipr-mtg; echo -e "${Y}⏸${N}" ;;
  start)    systemctl start hipr-mtg; echo -e "${G}▶${N}" ;;
  link)     load_cfg; echo "tg://proxy?server=${DOMAIN}&port=443&secret=${MTG_SECRET}" ;;
  theme)    echo "$(active_theme)" ;;
  qr)       load_cfg; qrencode -t ANSIUTF8 "https://t.me/proxy?server=${DOMAIN}&port=443&secret=${MTG_SECRET}" 2>/dev/null ;;
  watchdog) bash "$HIDE_DIR/bin/watchdog.sh" ;;
  help|--help|-h)
    echo -e "\n${BOLD}HIPR CLI${N}\n"
    echo -e "  ${W}hide${N}           — меню"
    echo -e "  ${W}hide status${N}    — статус"
    echo -e "  ${W}hide logs${N}      — live лог"
    echo -e "  ${W}hide link${N}      — ссылка tg://"
    echo -e "  ${W}hide qr${N}        — QR-код"
    echo -e "  ${W}hide theme${N}     — активная тема"
    echo -e "  ${W}hide restart${N}   — перезапустить"
    echo -e "  ${W}hide watchdog${N}  — запустить watchdog"
    echo "" ;;
  "")
    [[ $EUID -ne 0 ]] && echo -e "${Y}Рекомендуется sudo${N}\n"
    main_menu ;;
  *) echo -e "${R}Неизвестно: $1${N}  →  hide help" ;;
esac
