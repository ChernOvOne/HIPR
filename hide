_ping_proxy() {
  load_arrays; clear; echo -e "\n  ${BOLD}🔗 Проверка прокси${N}\n"
  local http_code; http_code=$(curl -sk -o /dev/null -w "%{http_code}" \
    "https://${DOMAIN:-localhost}" --max-time 5 2>/dev/null || echo "000")
  [[ "$http_code" == "200" || "$http_code" == "304" ]] \
    && echo -e "  🟢  Сайт-обманка: ${G}HTTP $http_code${N}" \
    || echo -e "  🔴  Сайт-обманка: ${R}HTTP $http_code${N}"

  echo ""
  for i in "${!SNI_DOMAINS_ARR[@]}"; do
    local port="${MTG_PORTS_ARR[$i]:-2398}"
    local sni="${SNI_DOMAINS_ARR[$i]}"
