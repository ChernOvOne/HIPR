_reinstall() {
  echo ""
  echo -e "  ${Y}⚠️  Будет запущен install.sh — текущая установка будет пересоздана.${N}"
  read -rp "  Продолжить? [y/N]: " c
  [[ "${c,,}" != "y" ]] && return
  local install_url="https://raw.githubusercontent.com/ChernOvOne/HIPR/main/install.sh"
  if curl -sf --max-time 5 "$install_url" > /dev/null 2>&1; then
    bash <(curl -fsSL "$install_url")
  else
    echo -e "\n  ${R}❌ GitHub недоступен. Скачайте install.sh вручную.${N}"
    sleep 3
  fi
}

_full_uninstall() {
  clear; echo ""
  echo -e "  ${R}${BOLD}⚠️  ПОЛНОЕ УДАЛЕНИЕ HIPR${N}\n"
  echo -e "  Будет удалено:"
  echo -e "  ${DIM}• Сервисы hipr-mtg, watchdog${N}"
  echo -e "  ${DIM}• /opt/hipr   /var/www/hipr   /usr/local/bin/hide${N}"
  echo -e "  ${DIM}• nginx конфиги hipr (сам nginx останется)${N}"
  echo -e "  ${DIM}• Cron задача certbot (сертификат останется)${N}"
  echo ""
  echo -e "  ${G}Останется:${N} ${DIM}nginx, certbot, Let's Encrypt сертификаты${N}"
  echo ""
  read -rp "  💾 Сохранить бэкап перед удалением? [Y/n]: " do_bak
  if [[ "${do_bak,,}" != "n" ]]; then
    local bak="/root/hipr_backup_$(date +%Y%m%d_%H%M%S)"
    mkdir -p "$bak"
    [[ -f "$CONFIG_FILE" ]]              && cp "$CONFIG_FILE" "$bak/"
    [[ -f "$HIDE_DIR/config/mtg.toml" ]] && cp "$HIDE_DIR/config/mtg.toml" "$bak/"
    [[ -d "$HIDE_DIR/themes/custom" ]]   && cp -r "$HIDE_DIR/themes/custom" "$bak/" 2>/dev/null || true
    cp -r /etc/letsencrypt/live "$bak/letsencrypt" 2>/dev/null || true
    echo -e "  ${G}💾 Бэкап: $bak${N}\n"
  fi
  read -rp "  Введите 'DELETE' для подтверждения: " confirm
  [[ "$confirm" != "DELETE" ]] && { echo -e "\n  Отменено."; sleep 2; return; }
  echo -e "\n  ${Y}🗑️  Удаляем...${N}\n"
  systemctl stop hipr-mtg hipr-watchdog.timer 2>/dev/null || true
  systemctl disable hipr-mtg hipr-watchdog.timer hipr-watchdog 2>/dev/null || true
  rm -f /etc/systemd/system/hipr-mtg.service
  rm -f /etc/systemd/system/hipr-watchdog.service
  rm -f /etc/systemd/system/hipr-watchdog.timer
  systemctl daemon-reload
  echo -e "  ${G}✓${N} Сервисы удалены"
  rm -f /etc/nginx/sites-enabled/hipr-{http,ssl,fallback}
  rm -f /etc/nginx/sites-available/hipr-{http,ssl,fallback}
  rm -f /etc/nginx/snippets/hipr-stream.conf
  rm -f /etc/nginx/modules-enabled/60-mod-hipr-stream.conf
  sed -i '/hipr-stream\.conf/d' /etc/nginx/nginx.conf 2>/dev/null || true
  nginx -t 2>/dev/null && systemctl reload nginx 2>/dev/null || true
  echo -e "  ${G}✓${N} nginx конфиги удалены"
  rm -rf /opt/hipr /var/www/hipr /usr/local/bin/hide
  echo -e "  ${G}✓${N} Файлы удалены"
  crontab -l 2>/dev/null | grep -v certbot | crontab - 2>/dev/null || true
  echo -e "  ${G}✓${N} Cron очищен"
  echo ""
  echo -e "  ${G}${BOLD}✅ HIPR полностью удалён${N}"
  echo -e "  ${DIM}nginx и сертификаты Let's Encrypt сохранены${N}"
  echo ""
  exit 0
}

# ══════════════════════════════════════════════════════════════════════════
# ТОЧКА ВХОДА
# ══════════════════════════════════════════════════════════════════════════
case "${1:-}" in
  status)
    load_cfg
    echo -e "$(svc_icon hipr-mtg)  hipr-mtg"
    echo -e "$(svc_icon nginx)  nginx"
    echo -e "$(svc_icon hipr-watchdog.timer 2>/dev/null)  watchdog"
    echo -e "🌐  Домен:  ${DOMAIN:-—}"
    echo -e "📡  DC:     ${ACTIVE_DC:-—}"
    echo -e "🎨  Тема:   $(active_theme)" ;;
  logs)      tail -f "$LOG_MTG" 2>/dev/null ;;
  restart)   systemctl restart hipr-mtg nginx; echo -e "${G}✅${N}" ;;
  stop)      systemctl stop hipr-mtg; echo -e "${Y}⏹️${N}" ;;
  start)     systemctl start hipr-mtg; echo -e "${G}▶️${N}" ;;
  link)      load_cfg; echo "tg://proxy?server=${DOMAIN}&port=443&secret=${MTG_SECRET}" ;;
  theme)     echo "$(active_theme)" ;;
  qr)        load_cfg
             qrencode -t ANSIUTF8 \
               "https://t.me/proxy?server=${DOMAIN}&port=443&secret=${MTG_SECRET}" \
               2>/dev/null || echo "apt install qrencode" ;;
  watchdog)  bash "$HIDE_DIR/bin/watchdog.sh" ;;
  uninstall) menu_uninstall ;;
  help|--help|-h)
    echo -e "\n${BOLD}🛡️  HIPR CLI${N} v${VERSION}\n"
    echo -e "  ${C}hide${N}             — интерактивное меню"
    echo -e "  ${C}hide status${N}      — быстрый статус"
    echo -e "  ${C}hide logs${N}        — live лог mtg"
    echo -e "  ${C}hide link${N}        — ссылка tg://"
    echo -e "  ${C}hide qr${N}          — QR-код"
    echo -e "  ${C}hide theme${N}       — активная тема"
    echo -e "  ${C}hide restart${N}     — перезапустить всё"
    echo -e "  ${C}hide watchdog${N}    — запустить watchdog"
    echo -e "  ${C}hide uninstall${N}   — удалить HIPR"
    echo "" ;;
  "")
    [[ $EUID -ne 0 ]] && echo -e "${Y}⚠️  Рекомендуется sudo${N}\n"
    main_menu ;;
  *) echo -e "${R}❌ Неизвестная команда: $1${N}  →  hide help" ;;
esac
