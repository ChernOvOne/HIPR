_speed_test() {
  load_cfg; load_arrays; clear
  echo -e "\n  ${BOLD}🔍 Диагностика сети${N}\n"
  echo -e "  ${DIM}Тест занимает ~15 секунд...${N}\n"

  # ── 1. Latency до всех Telegram DC ──────────────────────────────────────
  echo -e "  ${BOLD}📡 Latency до Telegram DC:${N}"
  declare -A DC_NAMES=(
    ["149.154.175.50"]="DC1 Miami      "
    ["149.154.167.51"]="DC2 Amsterdam  "
    ["149.154.175.100"]="DC3 Miami      "
    ["149.154.167.91"]="DC4 Amsterdam  "
    ["91.108.56.130"]="DC5 Singapore  "
  )

  local best_dc="" best_ms=99999
  for ip in "149.154.175.50" "149.154.167.51" "149.154.175.100" "149.154.167.91" "91.108.56.130"; do
    local name="${DC_NAMES[$ip]}"
    local active_mark=""; [[ "$ip" == "${ACTIVE_DC:-}" ]] && active_mark="${Y} ◀ активный${N}"
    local ping_out; ping_out=$(ping -c 3 -W 2 "$ip" 2>/dev/null)
    if echo "$ping_out" | grep -q "avg"; then
      local avg_ms; avg_ms=$(echo "$ping_out" | grep "avg" | awk -F'/' '{print $5}' | cut -d. -f1)
      local color="$G"
      (( avg_ms > 100 )) && color="$Y"
      (( avg_ms > 200 )) && color="$R"
      printf "  🟢  %-22s %-20s ${color}%d мс${N}%b\n" "$name" "$ip" "$avg_ms" "$active_mark"
      if (( avg_ms < best_ms )); then best_ms=$avg_ms; best_dc=$ip; fi
    else
      printf "  🔴  %-22s %-20s ${R}недоступен${N}%b\n" "$name" "$ip" "$active_mark"
    fi
  done

  echo ""
  if [[ -n "$best_dc" && "$best_dc" != "${ACTIVE_DC:-}" ]]; then
    echo -e "  ${Y}💡 Самый быстрый DC: ${BOLD}$best_dc${N} ${Y}(${best_ms} мс)${N}"
    echo -e "  ${DIM}   Текущий: ${ACTIVE_DC:-—}. Сменить: hide → [4] → [6]${N}"
  elif [[ -n "$best_dc" ]]; then
    echo -e "  ${G}✅ Активный DC оптимален (${best_ms} мс)${N}"
  fi

  # ── 2. Latency до ключевых серверов ─────────────────────────────────────
  echo -e "\n  ${BOLD}⏱️  Latency до ключевых серверов:${N}"

  _ping_host() {
    local label="$1" host="$2"
    local p; p=$(ping -c 3 -W 2 "$host" 2>/dev/null \
      | grep avg | awk -F'/' '{print $5}' | cut -d. -f1)
    if [[ -n "$p" ]]; then
      local color="$G"
      (( p > 80  )) && color="$Y"
      (( p > 150 )) && color="$R"
      printf "  🟢  %-26s ${color}%s мс${N}\n" "$label" "$p"
    else
      printf "  🔴  %-26s ${R}недоступен${N}\n" "$label"
    fi
  }

  echo -e "  ${DIM}Международные:${N}"
  _ping_host "Cloudflare (1.1.1.1)"    "1.1.1.1"
  _ping_host "Google (8.8.8.8)"        "8.8.8.8"

  echo -e "  ${DIM}Российские:${N}"
  _ping_host "Яндекс DNS (77.88.8.8)"  "77.88.8.8"
  _ping_host "yandex.ru"               "yandex.ru"
  _ping_host "vk.com"                  "vk.com"
  _ping_host "mail.ru"                 "mail.ru"
  _ping_host "sber.ru"                 "sber.ru"

  # ── 3. Проверка шейпинга ─────────────────────────────────────────────────
  echo -e "\n  ${BOLD}🔎 Проверка шейпинга трафика:${N}"

  local shaping_detected=false
  local shaping_reasons=()

  # Метод 1: TCP connect time на порт 443 к надёжным точкам
  # НЕ используем Яндекс — он намеренно медленно отвечает на TCP без QUIC
  # Используем серверы которые нормально отвечают на TCP:443
  echo -e "  ${DIM}TCP connect time (ICMP vs TCP:443):${N}"

  _tcp_latency() {
    local host="$1"
    python3 -c "
import socket, time
try:
    s = socket.socket()
    s.settimeout(3)
    t = time.time()
    s.connect(('$host', 443))
    s.close()
    print(int((time.time()-t)*1000))
except Exception as e:
    print('')
" 2>/dev/null
  }

  # vk.com и google надёжно отвечают на TCP:443
  for target in "vk.com" "google.com"; do
    local icmp_ms; icmp_ms=$(ping -c 3 -W 2 "$target" 2>/dev/null \
      | grep avg | awk -F'/' '{print $5}' | cut -d. -f1)
    local tcp_ms; tcp_ms=$(_tcp_latency "$target")

    if [[ -n "$icmp_ms" && -n "$tcp_ms" && "$tcp_ms" =~ ^[0-9]+$ && "$icmp_ms" -gt 0 ]]; then
      local ratio=$(( tcp_ms * 100 / icmp_ms ))
      if (( ratio > 500 && tcp_ms > 200 )); then
        # TCP в 5+ раз медленнее ICMP и >200мс — явный признак
        printf "  ${R}⚠️   %-12s ICMP %d мс  /  TCP:443 %d мс  → шейпинг${N}\n" \
          "$target" "$icmp_ms" "$tcp_ms"
        shaping_detected=true
        shaping_reasons+=("HTTPS трафик замедляется провайдером")
      else
        printf "  ${G}✅  %-12s ICMP %d мс  /  TCP:443 %d мс  → норма${N}\n" \
          "$target" "$icmp_ms" "$tcp_ms"
      fi
    else
      printf "  ${DIM}    %-12s не удалось замерить${N}\n" "$target"
    fi
  done

  # Метод 2: доступность Telegram DC на разных портах
  echo -e "\n  ${DIM}Доступность Telegram DC на портах:${N}"
  local dc="${ACTIVE_DC:-149.154.167.51}"
  local dc_443_ok=false
  for port in 443 80 5222; do
    if timeout 3 bash -c "echo '' > /dev/tcp/$dc/$port" 2>/dev/null; then
      printf "  ${G}✅  DC %-18s порт %-6s доступен${N}\n" "$dc" "$port"
      [[ "$port" == "443" ]] && dc_443_ok=true
    else
      printf "  ${R}🔴  DC %-18s порт %-6s заблокирован${N}\n" "$dc" "$port"
      if [[ "$port" == "443" ]]; then
        shaping_detected=true
        shaping_reasons+=("Telegram DC недоступен на порту 443")
      fi
    fi
  done

  # Метод 3: MTU пути до DC
  echo -e "\n  ${DIM}MTU на пути до Telegram DC:${N}"
  local mtu_problem=false
  for size in 1400 1200 1000; do
    if ping -c 1 -W 2 -M do -s $size "$dc" > /dev/null 2>&1; then
      printf "  ${G}✅  Пакет %d байт — проходит${N}\n" "$((size + 28))"
    else
      printf "  ${Y}⚠️   Пакет %d байт — не проходит${N}\n" "$((size + 28))"
      mtu_problem=true
    fi
  done
  if [[ "$mtu_problem" == "true" ]]; then
    shaping_detected=true
    shaping_reasons+=("MTU занижен — ТСПУ режет пакеты")
  fi

  # ── 4. Итог ─────────────────────────────────────────────────────────────
  echo ""
  echo -e "  ${B}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${N}"
  echo -e "  ${BOLD}💡 Вывод:${N}"

  if [[ "$shaping_detected" == "true" ]]; then
    echo -e "  ${R}⚠️  Обнаружены признаки шейпинга или блокировки:${N}"
    for reason in "${shaping_reasons[@]}"; do
      echo -e "  ${DIM}   • $reason${N}"
    done
    echo ""
    # Конкретные рекомендации зависят от причины
    if [[ "${shaping_reasons[*]}" == *"MTU"* ]]; then
      echo -e "  ${Y}→${N}  MTU проблема: прокси с FakeTLS уже помогает"
      echo -e "  ${DIM}   Дополнительно можно снизить MSS в mtg конфиге${N}"
    fi
    if [[ "${shaping_reasons[*]}" == *"443"* ]]; then
      echo -e "  ${Y}→${N}  Telegram DC заблокирован на 443 — попробуйте сменить DC:"
      echo -e "  ${DIM}   hide → [4] Управление сервисами → [6] Сменить Telegram DC${N}"
    fi
    if [[ "${shaping_reasons[*]}" == *"HTTPS"* ]]; then
      echo -e "  ${Y}→${N}  Шейпинг HTTPS со стороны VPS провайдера"
      echo -e "  ${DIM}   Это проблема хостинга, не прокси — рассмотрите смену VPS${N}"
    fi
  else
    echo -e "  ${G}✅ Шейпинга не обнаружено — прокси работает в нормальных условиях${N}"
  fi

  if (( best_ms > 150 )); then
    echo -e "\n  ${Y}⚠️  Высокая latency до DC ($best_ms мс)${N}"
    echo -e "  ${DIM}   Рекомендуется VPS в Европе (Hetzner DE/FI, Contabo DE)${N}"
  fi
  echo ""
  pause
}

