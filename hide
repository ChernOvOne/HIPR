    echo -e "  ${W}[3]${N}  Запустить hipr-mtg"
    echo -e "  ${W}[4]${N}  Перезапустить nginx"
    echo -e "  ${W}[5]${N}  Перезапустить всё"
    echo -e "  ${W}[6]${N}  Сменить Telegram DC"
