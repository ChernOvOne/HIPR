menu_logs() {
  while true; do
    clear; echo ""
    top_b
    printf "${B}  ║${N}  ${BOLD}%-55s${N}${B}║${N}\n" "Логи"
    sep
    kv "mtg.log:" "$(du -sh $LOG_MTG 2>/dev/null | cut -f1 || echo '0')"
    kv "watchdog.log:" "$(du -sh $LOG_WD 2>/dev/null | cut -f1 || echo '0')"
    kv "nginx:" "$(du -sh $LOG_NGX 2>/dev/null | cut -f1 || echo '0')"
    bot_b; echo ""
    echo -e "  ${W}[1]${N}  Последние 50 строк mtg"
    echo -e "  ${W}[2]${N}  Live-режим mtg (Ctrl+C выход)"
    echo -e "  ${W}[3]${N}  Watchdog лог"
    echo -e "  ${W}[4]${N}  nginx access лог"
    echo -e "  ${W}[5]${N}  Статистика за сегодня"
    echo -e "  ${W}[6]${N}  Очистить все логи"
    echo ""; echo -e "  ${R}[0]${N}  Назад"; echo ""
    read -rp "  Выберите: " ch
    case "$ch" in
      1) clear; tail -50 "$LOG_MTG" 2>/dev/null | grep --color=always -E 'accepted|ERROR|WARN|$'; echo ""; read -rp "  [Enter]" _ ;;
      2) tail -f "$LOG_MTG" 2>/dev/null ;;
      3) clear; tail -50 "$LOG_WD" 2>/dev/null || echo "  Пусто"; read -rp "  [Enter]" _ ;;
      4) clear; tail -50 "$LOG_NGX" 2>/dev/null || echo "  Пусто"; read -rp "  [Enter]" _ ;;
      5) _stats_today ;;
      6) read -rp "  Очистить? [y/N]: " c
         [[ "${c,,}" == "y" ]] && { > "$LOG_MTG"; > "$LOG_WD"; echo -e "  ${G}✓${N}"; sleep 1; } ;;
      0|q) return ;;
    esac
  done
}

_stats_today() {
  clear; echo -e "\n  ${BOLD}Статистика за сегодня:${N}\n"
  local today; today=$(date '+%Y/%m/%d')
  local conns; conns=$(grep -c "accepted connection" "$LOG_MTG" 2>/dev/null || echo "0")
  local today_c; today_c=$(grep "$today" "$LOG_MTG" 2>/dev/null | grep -c "accepted" || echo "0")
  local errors; errors=$(grep -c "ERROR" "$LOG_MTG" 2>/dev/null || echo "0")
  local wd_switches; wd_switches=$(grep -c "Переключаемся" "$LOG_WD" 2>/dev/null || echo "0")
  printf "  %-28s ${Y}%s${N}\n" "Соединений сегодня:" "$today_c"
  printf "  %-28s ${Y}%s${N}\n" "Всего соединений:" "$conns"
  printf "  %-28s ${R}%s${N}\n" "Ошибок:" "$errors"
  printf "  %-28s ${C}%s${N}\n" "Смен DC (watchdog):" "$wd_switches"
  echo ""; read -rp "  [Enter]" _
}

