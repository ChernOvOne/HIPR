HIDE_DIR="/opt/hipr"
CONFIG_FILE="$HIDE_DIR/config.env"
MTG_BIN="$HIDE_DIR/bin/mtg"
HIDE_BIN="/usr/local/bin/hide"
WEB_DIR="/var/www/hipr"
THEMES_LOCAL="$HIDE_DIR/themes"
THEMES_API="https://api.github.com/repos/ChernOvOne/HIPR/contents/themes"
THEMES_RAW="https://raw.githubusercontent.com/ChernOvOne/HIPR/main/themes"
LOG_WD="$HIDE_DIR/logs/watchdog.log"
LOG_NGX="$HIDE_DIR/logs/nginx-access.log"
VERSION="4.0"

# ── Цвета — $'...' синтаксис, работает везде включая read -rp ─────────────
R=$'\033[0;31m'
G=$'\033[0;32m'
Y=$'\033[1;33m'
B=$'\033[0;34m'
C=$'\033[0;36m'
W=$'\033[1;37m'
N=$'\033[0m'
BOLD=$'\033[1m'
DIM=$'\033[2m'

# ── Утилиты ────────────────────────────────────────────────────────────────
load_cfg() { [[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE" || true; }
top_b()    { echo -e "${B}  ╔══════════════════════════════════════════════════════════╗${N}"; }
bot_b()    { echo -e "${B}  ╚══════════════════════════════════════════════════════════╝${N}"; }
sep()      { echo -e "${B}  ╠══════════════════════════════════════════════════════════╣${N}"; }
row()      { printf "${B}  ║${N} %-57s${B}║${N}\n" "$1"; }
kv()       { printf "${B}  ║${N}  ${DIM}%-16s${N} ${W}%-39s${N}${B}║${N}\n" "$1" "$2"; }
kvc()      { printf "${B}  ║${N}  ${DIM}%-16s${N} ${C}%-39s${N}${B}║${N}\n" "$1" "$2"; }
pause()    { echo ""; read -rp "  Нажмите Enter для продолжения..." _; }

svc_icon() {
  systemctl is-active --quiet "$1" 2>/dev/null && echo "🟢" || echo "🔴"
}
svc_status() {
  systemctl is-active --quiet "$1" 2>/dev/null \
    && echo -e "${G}🟢 работает${N}" || echo -e "${R}🔴 остановлен${N}"
}

active_theme() {
  [[ -f "$HIDE_DIR/config/active_theme" ]] && cat "$HIDE_DIR/config/active_theme" || echo "—"
}

# ── Загрузка массивов из config.env ───────────────────────────────────────
load_arrays() {
  load_cfg
  IFS='|' read -ra SNI_DOMAINS_ARR    <<< "${SNI_DOMAINS:-microsoft.com}"
  IFS='|' read -ra MTG_SECRETS_ARR    <<< "${MTG_SECRETS:-}"
  IFS='|' read -ra MTG_PORTS_ARR      <<< "${MTG_PORTS:-2398}"
  IFS='|' read -ra MTG_PROM_PORTS_ARR <<< "${MTG_PROM_PORTS:-3129}"
}

# ── Получить имя сервиса mtg по индексу ───────────────────────────────────
mtg_svc() {
  local i=$1
  load_cfg
  if [[ "${MODE:-single}" == "multi" ]]; then
    echo "hipr-mtg@${i}"
  else
    echo "hipr-mtg"
  fi
}

# ── Получить метрики всех инстансов ───────────────────────────────────────
get_stats() {
  load_arrays
  STAT_ACTIVE=0; STAT_TG=0; STAT_BYTES=0; STAT_REPLAYS=0
  STAT_FRONTING=0; STAT_BYTES_FMT="—"

  local total_bytes=0
  for port in "${MTG_PROM_PORTS_ARR[@]}"; do
    local m
    m=$(curl -sf --max-time 2 "http://127.0.0.1:${port}/metrics" 2>/dev/null)
    [[ -z "$m" ]] && continue

    STAT_ACTIVE=$(( STAT_ACTIVE + $(echo "$m" | grep '^mtg_client_connections{' \
      | awk '{sum+=$2} END{print int(sum)}') ))
    STAT_TG=$(( STAT_TG + $(echo "$m" | grep '^mtg_telegram_connections{' \
      | awk '{sum+=$2} END{print int(sum)}') ))
    STAT_REPLAYS=$(( STAT_REPLAYS + $(echo "$m" | grep '^mtg_replay_attacks ' \
      | awk '{print int($2)}') ))
    STAT_FRONTING=$(( STAT_FRONTING + $(echo "$m" | grep '^mtg_domain_fronting ' \
      | awk '{print int($2)}') ))
    local b
    b=$(echo "$m" | grep '^mtg_telegram_traffic{' | awk '{sum+=$2} END{print int(sum)}')
    total_bytes=$(( total_bytes + b ))
  done

  if (( total_bytes > 1073741824 )); then
    STAT_BYTES_FMT=$(python3 -c "print(f'{$total_bytes/1073741824:.1f} GB')" 2>/dev/null)
  elif (( total_bytes > 1048576 )); then
    STAT_BYTES_FMT=$(python3 -c "print(f'{$total_bytes/1048576:.1f} MB')" 2>/dev/null)
  elif (( total_bytes > 0 )); then
    STAT_BYTES_FMT=$(python3 -c "print(f'{$total_bytes/1024:.1f} KB')" 2>/dev/null)
  else
    STAT_BYTES_FMT="0 B"
  fi
  STAT_BYTES=$total_bytes
}

# ── Шапка ─────────────────────────────────────────────────────────────────

# ══════════════════════════════════════════════════════════════════════════
# АВТОДИАГНОСТИКА — запускается при открытии главного меню
# ══════════════════════════════════════════════════════════════════════════
_autocheck() {
  load_cfg; load_arrays
  local issues=() fixes=()

  # 1. Сертификат
  local CERT_PATH="/etc/letsencrypt/live/${DOMAIN:-_}/fullchain.pem"
  if [[ ! -f "$CERT_PATH" ]]; then
    issues+=("🔴 TLS сертификат отсутствует")
    fixes+=("cert")
  fi

  # 2. SSL nginx блок
  if [[ ! -f "/etc/nginx/sites-available/hipr-ssl" ]]; then
    issues+=("🔴 nginx SSL блок отсутствует")
    fixes+=("cert")
  fi

  # 3. Stream конфиг
  if [[ ! -f "/etc/nginx/snippets/hipr-stream.conf" ]]; then
    issues+=("🔴 nginx stream конфиг отсутствует")
    fixes+=("cert")
  fi

  # 4. IPv6 зависшие SYN-SENT
  local syn_count; syn_count=$(ss -tn state syn-sent 2>/dev/null | grep -c mtg || echo 0)
  if [[ "$syn_count" -gt 5 ]]; then
    issues+=("🟡 IPv6 SYN-SENT зависших: $syn_count (mtg не может достучаться до Telegram)")
    fixes+=("ipv6")
  fi

  # 5. nginx не слушает 443
  if ! ss -tlnp 2>/dev/null | grep -q '0.0.0.0:443'; then
    issues+=("🔴 nginx не слушает порт 443")
    fixes+=("nginx")
  fi

  [[ ${#issues[@]} -eq 0 ]] && return 0

  echo -e "${Y}${BOLD}  ⚠️  Обнаружены проблемы:${N}"
  for issue in "${issues[@]}"; do
    echo -e "  $issue"
  done
  echo ""
  read -rp "  Исправить автоматически? [Y/n]: " fix_choice
  [[ "${fix_choice,,}" == "n" ]] && return 0

  # Применяем фиксы (уникальные)
  local done_fixes=""
  for fix in "${fixes[@]}"; do
    [[ "$done_fixes" == *"$fix"* ]] && continue
    done_fixes="$done_fixes $fix"
    case "$fix" in
      cert)
        echo -e "  ${Y}→ Восстанавливаем TLS и nginx конфиги...${N}"
        _renew_cert ;;
      ipv6)
        echo -e "  ${Y}→ Отключаем IPv6...${N}"
        local iface; iface=$(ip route | grep default | awk '{print $5}' | head -1)
        iface="${iface:-eth0}"
        sysctl -w net.ipv6.conf.all.disable_ipv6=1 > /dev/null 2>&1
        sysctl -w net.ipv6.conf.default.disable_ipv6=1 > /dev/null 2>&1
        sysctl -w "net.ipv6.conf.${iface}.disable_ipv6=1" > /dev/null 2>&1
        grep -q 'disable_ipv6' /etc/sysctl.d/99-hipr.conf 2>/dev/null || {
          printf 'net.ipv6.conf.all.disable_ipv6 = 1
net.ipv6.conf.default.disable_ipv6 = 1
net.ipv6.conf.%s.disable_ipv6 = 1
' "$iface"             >> /etc/sysctl.d/99-hipr.conf
        }
        # Перезапускаем mtg без зависания
        if [[ "${MODE:-single}" == "multi" ]]; then
          for i in "${!SNI_DOMAINS_ARR[@]}"; do
            systemctl stop "hipr-mtg@${i}" 2>/dev/null || true
          done
          sleep 2
          for i in "${!SNI_DOMAINS_ARR[@]}"; do
            systemctl start "hipr-mtg@${i}" 2>/dev/null || true
            sleep 1
          done
        else
          systemctl stop hipr-mtg 2>/dev/null || true
          sleep 2
          systemctl start hipr-mtg 2>/dev/null || true
        fi
        echo -e "  ${G}✅ IPv6 отключён, mtg перезапущен${N}" ;;
      nginx)
        echo -e "  ${Y}→ Перезапускаем nginx...${N}"
        nginx -t 2>/dev/null && systemctl restart nginx 2>/dev/null           && echo -e "  ${G}✅ nginx перезапущен${N}"           || echo -e "  ${R}❌ Ошибка nginx — проверьте nginx -t${N}" ;;
    esac
  done
  echo ""; sleep 1
}

draw_header() {
  load_cfg; get_stats; clear
  echo -e "${C}${BOLD}"
  echo "   ██╗  ██╗██╗██████╗ ██████╗ "
  echo "   ██║  ██║██║██╔══██╗██╔══██╗"
  echo "   ███████║██║██████╔╝██████╔╝"
  echo "   ██╔══██║██║██╔═══╝ ██╔══██╗"
  echo "   ██║  ██║██║██║     ██║  ██║"
  echo "   ╚═╝  ╚═╝╚═╝╚═╝     ╚═╝  ╚═╝  v${VERSION}  [${MODE:-single}]"
  echo -e "${N}"

  local mtg_icon nginx_icon wd_icon dns_icon
  if [[ "${MODE:-single}" == "multi" ]]; then
    load_arrays
    local all_ok=true
    for i in "${!SNI_DOMAINS_ARR[@]}"; do
      systemctl is-active --quiet "hipr-mtg@${i}" 2>/dev/null || all_ok=false
    done
    [[ "$all_ok" == "true" ]] && mtg_icon="🟢" || mtg_icon="🟡"
  else
    mtg_icon=$(svc_icon hipr-mtg)
  fi
  nginx_icon=$(svc_icon nginx)
  wd_icon=$(svc_icon hipr-watchdog.timer 2>/dev/null)
  dns_icon=$(svc_icon dnsproxy)

  top_b
  printf "${B}  ║${N}  %s %-11s %s %-9s %s %-11s %s %-9s${B}║${N}\n" \
    "$mtg_icon" "mtg" "$nginx_icon" "nginx" "$wd_icon" "watchdog" "$dns_icon" "dnsproxy"
  sep
  kv  "🌐 Домен:"  "${DOMAIN:-не задан}"
  kvc "📡 DC:"      "${ACTIVE_DC:-—}"
  kv  "🎨 Тема:"   "$(active_theme)"
  kv  "⚙️  Режим:"  "${MODE:-single}"
  local ipv6_status
  sysctl -n net.ipv6.conf.all.disable_ipv6 2>/dev/null | grep -q "1" \
    && ipv6_status="отключён" || ipv6_status="включён"
  kv  "🌐 IPv6:"     "$ipv6_status"
  sep
  # Telegram открывает 3-8 TCP-соединений на клиента — делим для оценки реальных юзеров
  local ESTIMATED_USERS=$(( STAT_ACTIVE > 0 ? (STAT_ACTIVE + 3) / 4 : 0 ))
  printf "${B}  ║${N}  🟢 ${DIM}~юзер${N} ${Y}%-4s${N}  📡 ${DIM}conn${N} ${Y}%-4s${N}  📦 ${DIM}Трафик${N} ${Y}%-10s${N}  🛡️  ${DIM}Атак${N} ${Y}%-4s${N}${B}║${N}\n" \
    "$ESTIMATED_USERS" "$STAT_ACTIVE" "$STAT_BYTES_FMT" "$STAT_REPLAYS"
  row ""; bot_b; echo ""
}

# ══════════════════════════════════════════════════════════════════════════
# ГЛАВНОЕ МЕНЮ
# ══════════════════════════════════════════════════════════════════════════
main_menu() {
  local _first_run=true
  while true; do
    if [[ "$_first_run" == "true" ]]; then
      _first_run=false
      load_cfg
      if [[ -f "/opt/hipr/config.env" && -n "${DOMAIN:-}" ]]; then
        _autocheck
      fi
    fi
    draw_header
    echo -e "  ${BOLD}${W}Главное меню${N}\n"
    echo -e "  ${C}[1]${N}  📊  Мониторинг и статус"
    echo -e "  ${C}[2]${N}  🔗  Прокси и подключения"
    echo -e "  ${C}[3]${N}  ⚙️   Управление сервисами"
    echo -e "  ${C}[4]${N}  🔧  Настройки"
    echo -e "  ${C}[5]${N}  🔔  Уведомления и бот"
    echo -e "  ${C}[6]${N}  🎨  Темы сайта-обманки"
    echo -e "  ${C}[7]${N}  🔄  Обновление"
    echo ""
    echo -e "  ${R}[9]${N}  🗑️   Удалить / Переустановить"
    echo -e "  ${DIM}[0]${N}  🚪  Выход"
    echo ""
    read -rp "  Выберите [0-9]: " ch
    case "$ch" in
      1) menu_monitor ;;
      2) menu_proxy ;;
      3) menu_services ;;
      4) menu_settings ;;
      5) menu_notifications ;;
      6) menu_themes ;;
      7) menu_update ;;
      9) menu_uninstall ;;
      0|q|Q) echo ""; exit 0 ;;
      *) echo -e "\n  ${R}Неверный выбор${N}"; sleep 1 ;;
    esac
  done
}

# ══════════════════════════════════════════════════════════════════════════
# 1. МОНИТОРИНГ И СТАТУС
# ══════════════════════════════════════════════════════════════════════════
menu_monitor() {
  while true; do
    load_cfg; get_stats; load_arrays; clear; echo ""
    top_b
    printf "${B}  ║${N}  ${BOLD}📊 %-53s${N}${B}║${N}\n" "Мониторинг и статус"
    sep

    # Сервисы
    if [[ "${MODE:-single}" == "multi" ]]; then
      for i in "${!SNI_DOMAINS_ARR[@]}"; do
        printf "${B}  ║${N}  %-20s %-37b${B}║${N}\n"           "mtg@${i} (${SNI_DOMAINS_ARR[$i]})" "$(svc_status "hipr-mtg@${i}")"
      done
    else
      printf "${B}  ║${N}  %-20s %-37b${B}║${N}\n" "hipr-mtg" "$(svc_status hipr-mtg)"
    fi
    for s in nginx dnsproxy; do
      printf "${B}  ║${N}  %-20s %-37b${B}║${N}\n" "$s" "$(svc_status $s)"
    done
    sep

    # Системные ресурсы
    local cpu_load; cpu_load=$(uptime | awk -F'load average:' '{print $2}' | awk '{print $1}' | tr -d ',')
    local cpu_cores; cpu_cores=$(nproc 2>/dev/null || echo 1)
    local mem_used; mem_used=$(free -m | awk '/Mem:/{print $3}')
    local mem_total; mem_total=$(free -m | awk '/Mem:/{print $2}')
    local mem_pct; mem_pct=$(free -m | awk '/Mem:/{printf "%.0f", $3/$2*100}' | tr -d '[:space:]')
    mem_pct="${mem_pct//[^0-9]/}"; mem_pct="${mem_pct:-0}"
    local disk_used; disk_used=$(df -h / | awk 'NR==2{print $3}')
    local disk_total; disk_total=$(df -h / | awk 'NR==2{print $2}')
    local disk_pct; disk_pct=$(df / | awk 'NR==2{print $5}' | tr -d '%[:space:]')
    disk_pct="${disk_pct//[^0-9]/}"; disk_pct="${disk_pct:-0}"
    local uptime_str; uptime_str=$(uptime -p 2>/dev/null | sed 's/up //' || uptime | awk '{print $3}' | tr -d ',')

    # Цветовая индикация нагрузки
    local cpu_color="$G"
    local cpu_pct; cpu_pct=$(echo "$cpu_load $cpu_cores" | awk '{printf "%d", $1/$2*100}' 2>/dev/null || echo 0)
    cpu_pct="${cpu_pct//[^0-9]/}"
    cpu_pct="${cpu_pct:-0}"
    [[ "$cpu_pct" -gt 80 ]] 2>/dev/null && cpu_color="$R"
    [[ "$cpu_pct" -gt 50 && "$cpu_pct" -le 80 ]] 2>/dev/null && cpu_color="$Y"

    kv "💻 CPU load:" "${cpu_load} (${cpu_cores} ядер)"
    kv "💾 RAM:" "${mem_used}/${mem_total} MB (${mem_pct}%)"
    kv "💿 Диск:" "${disk_used}/${disk_total} (${disk_pct}%)"
    kv "⏱️  Uptime:" "$uptime_str"
    sep

    # Статистика прокси
    local ESTIMATED_USERS=$(( STAT_ACTIVE > 0 ? (STAT_ACTIVE + 3) / 4 : 0 ))
    kv "🟢 ~Пользователей:" "$ESTIMATED_USERS сейчас"
    kv "📡 TCP соединений:" "$STAT_ACTIVE активных"
    kv "📦 Трафик (total):" "$STAT_BYTES_FMT"
    kv "🛡️  Replay атак:" "$STAT_REPLAYS"
    kv "🎭 FakeTLS:" "$STAT_FRONTING handshakes"
    local ce; ce=$(certbot certificates 2>/dev/null | grep -A3 "${DOMAIN:-_}"       | grep "Expiry" | awk '{print $3,$4}' | head -1)
    kv "🔒 Сертификат:" "${ce:-—}"
    sep

    # Статистика по инстансам
    if [[ "${MODE:-single}" == "multi" ]]; then
      IFS='|' read -ra _PPORTS <<< "${MTG_PROM_PORTS:-3129}"
      IFS='|' read -ra _SNIS_M <<< "${SNI_DOMAINS:-}"
      for i in "${!_PPORTS[@]}"; do
        local inst_conn; inst_conn=$(curl -sf --max-time 2           "http://127.0.0.1:${_PPORTS[$i]}/metrics" 2>/dev/null |           grep '^mtg_client_connections{' | awk '{sum+=$2} END{print int(sum)+0}')
        local inst_users=$(( inst_conn > 0 ? (inst_conn+3)/4 : 0 ))
        kv "  [${i}] ${_SNIS_M[$i]:-?}:" "~${inst_users} польз / ${inst_conn} conn"
      done
      sep
    fi

    kv "🌐 Домен:" "${DOMAIN:-—}"
    kvc "📡 Активный DC:" "${ACTIVE_DC:-—}"
    row ""; bot_b; echo ""

    echo -e "  ${C}[r]${N} Обновить  ${C}[t]${N} Тест DC  ${C}[p]${N} Пинг прокси  ${C}[s]${N} Диагностика сети  ${C}[d]${N} Диагностика системы  ${R}[0]${N} Назад"
    echo ""
    read -rp "  " ch
    case "$ch" in
      r|R) continue ;;
      t|T) _check_all_dc ;;
      p|P) _ping_proxy ;;
      s|S) _speed_test ;;
      d|D) _system_diag ;;
      0|q) return ;;
    esac
  done
}

_system_diag() {
  clear; echo ""
  echo -e "  ${BOLD}🔍 Диагностика системы HIPR${N}\n"
  local issues=0

  # IPv6 / SYN-SENT
  local syn_count; syn_count=$(ss -tn state syn-sent 2>/dev/null | grep -c mtg || echo 0)
  if [[ "$syn_count" -gt 5 ]]; then
    echo -e "  ${R}✗${N} IPv6 SYN-SENT: $syn_count зависших (mtg не может достучаться до Telegram)"
    echo -e "     ${DIM}→ Исправить: Настройки → Сеть → IPv6${N}"
    ((issues++))
  else
    echo -e "  ${G}✓${N} IPv6/SYN-SENT: норма ($syn_count)"
  fi

  # Сертификат
  if [[ -f "/etc/letsencrypt/live/${DOMAIN:-_}/fullchain.pem" ]]; then
    local exp; exp=$(certbot certificates 2>/dev/null | grep -A3 "${DOMAIN:-_}" | grep Expiry | awk '{print $3}')
    echo -e "  ${G}✓${N} TLS сертификат: действителен до $exp"
  else
    echo -e "  ${R}✗${N} TLS сертификат: отсутствует"
    echo -e "     ${DIM}→ Исправить: Настройки → Сеть → Обновить TLS${N}"
    ((issues++))
  fi

  # Stream конфиг
  if [[ -f "/etc/nginx/snippets/hipr-stream.conf" ]]; then
    echo -e "  ${G}✓${N} nginx stream конфиг: найден"
  else
    echo -e "  ${R}✗${N} nginx stream конфиг: отсутствует (порт 443 не роутит на mtg)"
    ((issues++))
  fi

  # nginx порт 443
  if ss -tlnp 2>/dev/null | grep -q '0.0.0.0:443'; then
    echo -e "  ${G}✓${N} nginx: слушает порт 443"
  else
    echo -e "  ${R}✗${N} nginx: порт 443 не слушается"
    ((issues++))
  fi

  # mtg процессы
  local mtg_count; mtg_count=$(pgrep -x mtg | wc -l)
  if [[ "$mtg_count" -gt 0 ]]; then
    echo -e "  ${G}✓${N} mtg: $mtg_count процессов запущено"
  else
    echo -e "  ${R}✗${N} mtg: нет запущенных процессов"
    ((issues++))
  fi

  # Telegram DC доступность
  local dc_ok=0; local dc_fail=0
  for dc in "149.154.175.50" "149.154.167.51" "149.154.175.100" "149.154.167.91" "91.108.56.130"; do
    timeout 3 bash -c "echo '' > /dev/tcp/$dc/443" 2>/dev/null && ((dc_ok++)) || ((dc_fail++))
  done
  if [[ "$dc_fail" -eq 0 ]]; then
    echo -e "  ${G}✓${N} Telegram DC: все 5 доступны"
  elif [[ "$dc_ok" -gt 0 ]]; then
    echo -e "  ${Y}⚠${N} Telegram DC: $dc_ok/5 доступны"
  else
    echo -e "  ${R}✗${N} Telegram DC: все недоступны!"
    ((issues++))
  fi

  # RAM
  local mem_pct; mem_pct=$(free -m | awk '/Mem:/{printf "%.0f", $3/$2*100}' | tr -d '[:space:]')
  mem_pct="${mem_pct//[^0-9]/}"; mem_pct="${mem_pct:-0}"
  if [[ "$mem_pct" -gt 90 ]]; then
    echo -e "  ${R}✗${N} RAM: ${mem_pct}% занято — критично"
    ((issues++))
  elif [[ "$mem_pct" -gt 75 ]]; then
    echo -e "  ${Y}⚠${N} RAM: ${mem_pct}% занято — высокое"
  else
    echo -e "  ${G}✓${N} RAM: ${mem_pct}% занято"
  fi

  # Disk
  local disk_pct; disk_pct=$(df / | awk 'NR==2{print $5}' | tr -d '%[:space:]')
  disk_pct="${disk_pct//[^0-9]/}"; disk_pct="${disk_pct:-0}"
  if [[ "$disk_pct" -gt 90 ]]; then
    echo -e "  ${R}✗${N} Диск: ${disk_pct}% занято — критично"
    ((issues++))
  elif [[ "$disk_pct" -gt 75 ]]; then
    echo -e "  ${Y}⚠${N} Диск: ${disk_pct}% занято — высокое"
  else
    echo -e "  ${G}✓${N} Диск: ${disk_pct}% занято"
  fi

  echo ""
  if [[ "$issues" -eq 0 ]]; then
    echo -e "  ${G}${BOLD}✅ Всё в порядке${N}"
  else
    echo -e "  ${R}${BOLD}Обнаружено проблем: $issues${N}"
  fi
  echo ""; pause
}

