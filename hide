      2) systemctl stop hipr-mtg; echo -e "\n  ${Y}⏸ Остановлен${N}"; sleep 2 ;;
      3) systemctl start hipr-mtg && echo -e "\n  ${G}▶ Запущен${N}"; sleep 2 ;;
      4) nginx -t && systemctl reload nginx && echo -e "\n  ${G}✓ nginx${N}"; sleep 2 ;;
      5) systemctl restart hipr-mtg nginx && echo -e "\n  ${G}✓ Всё перезапущено${N}"; sleep 2 ;;
      6) _change_dc ;;
      7) bash "$HIDE_DIR/bin/watchdog.sh" && echo -e "\n  ${G}✓ Watchdog запущен${N}"; sleep 2 ;;
