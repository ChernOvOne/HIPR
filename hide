_send_links_to_bot() {
  load_cfg; load_arrays
  [[ -z "${BOT_TOKEN:-}" || -z "${BOT_CHAT_ID:-}" ]] && {
    echo -e "\n  ${Y}⚠️  Бот не настроен → hide → [6] Настройки → Telegram бот${N}"
    sleep 2; return; }

  local msg="🔗 <b>HIPR прокси ссылки</b>%0A%0A"
  for i in "${!SNI_DOMAINS_ARR[@]}"; do
    local tg="tg://proxy?server=${DOMAIN}&port=443&secret=${MTG_SECRETS_ARR[$i]}"
    msg="${msg}[$((i+1))] SNI: ${SNI_DOMAINS_ARR[$i]}%0A<code>${tg}</code>%0A%0A"
  done
  msg="${msg}🌐 ${DOMAIN}"

  curl -s --max-time 10 \
    "https://api.telegram.org/bot${BOT_TOKEN}/sendMessage" \
    -d "chat_id=${BOT_CHAT_ID}&text=${msg}&parse_mode=HTML" > /dev/null 2>&1 \
    && echo -e "\n  ${G}✅ Отправлено в бот${N}" \
    || echo -e "\n  ${R}❌ Ошибка отправки${N}"
  sleep 2
}

