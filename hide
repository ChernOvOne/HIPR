_regen_secret() {
  echo ""
  read -rp "  Сгенерировать новый секрет? Все старые ссылки перестанут работать! [y/N]: " c
  [[ "${c,,}" != "y" ]] && return
  load_cfg
  local new_secret
  if [[ -x "$MTG_BIN" ]]; then
    new_secret=$("$MTG_BIN" generate-secret --hex "${DOMAIN:-localhost}" 2>/dev/null | tr -d '\n')
  fi
  if [[ -z "${new_secret:-}" ]]; then
    local rh; rh=$(openssl rand -hex 16)
    local dh; dh=$(echo -n "${DOMAIN:-x}" | xxd -p | tr -d '\n')
    new_secret="ee${rh}${dh}"
  fi
  sed -i "s|MTG_SECRET=.*|MTG_SECRET=\"$new_secret\"|" "$CONFIG_FILE"
  # Обновляем mtg.toml
  sed -i "s|^secret = .*|secret = \"$new_secret\"|" "$HIDE_DIR/config/mtg.toml"
  systemctl restart hipr-mtg
  echo -e "\n  ${G}✓ Новый секрет применён${N}"
  echo -e "  ${Y}Раздайте новую ссылку: hide → пункт 2${N}"
  sleep 3
}

_renew_cert() {
  load_cfg; echo ""
  echo -e "  ${Y}Обновляем сертификат для $DOMAIN...${N}\n"
  if certbot renew --force-renewal -d "${DOMAIN:-}" 2>&1 | tail -8; then
    systemctl reload nginx
    echo -e "\n  ${G}✓ Сертификат обновлён${N}"
  else
    echo -e "\n  ${R}✗ Ошибка — проверьте DNS${N}"
  fi
  sleep 3
}

_setup_bot() {
  clear; echo -e "\n  ${BOLD}Настройка Telegram-бота${N}\n"
  echo -e "  1. Откройте @BotFather в Telegram"
  echo -e "  2. Создайте бота: /newbot"
  echo -e "  3. Скопируйте токен"
  echo -e "  4. Напишите боту /start"
  echo -e "  5. Перейдите: https://api.telegram.org/bot<TOKEN>/getUpdates"
  echo -e "     чтобы узнать ваш chat_id\n"
  read -rp "  Bot Token: " tok
  [[ -z "$tok" ]] && return
  read -rp "  Chat ID: " cid
  [[ -z "$cid" ]] && return
  # Тест
  if curl -sf --max-time 10 \
    "https://api.telegram.org/bot${tok}/sendMessage" \
    -d "chat_id=${cid}&text=✅ HIPR бот подключён!" > /dev/null 2>&1; then
    sed -i "s|BOT_TOKEN=.*|BOT_TOKEN=\"$tok\"|" "$CONFIG_FILE"
    sed -i "s|BOT_CHAT_ID=.*|BOT_CHAT_ID=\"$cid\"|" "$CONFIG_FILE"
    echo -e "\n  ${G}✓ Бот настроен — проверьте сообщение в Telegram${N}"
  else
    echo -e "\n  ${R}✗ Ошибка — проверьте токен и chat_id${N}"
  fi
  sleep 3
}

