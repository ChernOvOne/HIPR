menu_services() {
  while true; do
    load_cfg; load_arrays; clear; echo ""
    top_b
    printf "${B}  ║${N}  ${BOLD}⚙️  %-53s${N}${B}║${N}\n" "Управление сервисами"
    sep; row ""

    if [[ "${MODE:-single}" == "multi" ]]; then
      for i in "${!SNI_DOMAINS_ARR[@]}"; do
        printf "${B}  ║${N}  %-20s %-37b${B}║${N}\n" \
          "mtg@${i} (${SNI_DOMAINS_ARR[$i]})" "$(svc_status "hipr-mtg@${i}")"
      done
    else
      printf "${B}  ║${N}  %-20s %-37b${B}║${N}\n" "hipr-mtg" "$(svc_status hipr-mtg)"
    fi
    printf "${B}  ║${N}  %-20s %-37b${B}║${N}\n" "dnsproxy" "$(svc_status dnsproxy)"
    row ""; bot_b; echo ""

    echo -e "  ${C}[1]${N}  🔄  Перезапустить все mtg"
    echo -e "  ${C}[2]${N}  ⏹️   Остановить все mtg"
    echo -e "  ${C}[3]${N}  ▶️   Запустить все mtg"
    echo -e "  ${C}[4]${N}  🔄  Перезапустить nginx"
    echo -e "  ${C}[5]${N}  🔄  Перезапустить всё"
    echo -e "  ${C}[6]${N}  📡  Сменить Telegram DC"
    echo -e "  ${C}[7]${N}  🐕  Запустить watchdog вручную"
    echo ""; echo -e "  ${R}[0]${N}  ← Назад"; echo ""
    read -rp "  Выберите: " ch
    case "$ch" in
      1) _mtg_action restart ;;
      2) _mtg_action stop ;;
      3) _mtg_action start ;;
      4) nginx -t 2>/dev/null && systemctl reload nginx \
           && echo -e "\n  ${G}✅ nginx перезагружен${N}"; sleep 2 ;;
      5)
         echo -e "\n  ${Y}Перезапускаем сервисы...${N}"
         load_cfg; load_arrays
         if [[ "${MODE:-single}" == "multi" ]]; then
           for i in "${!SNI_DOMAINS_ARR[@]}"; do
             systemctl restart "hipr-mtg@${i}" 2>/dev/null \
               && echo -e "  ${G}✅ hipr-mtg@${i}${N}" \
               || echo -e "  ${R}❌ hipr-mtg@${i}${N}"
           done
         else
           systemctl restart hipr-mtg 2>/dev/null \
             && echo -e "  ${G}✅ hipr-mtg${N}" \
             || echo -e "  ${R}❌ hipr-mtg${N}"
         fi
         systemctl restart dnsproxy 2>/dev/null \
           && echo -e "  ${G}✅ dnsproxy${N}" || echo -e "  ${R}❌ dnsproxy${N}"
         nginx -t 2>/dev/null \
           && systemctl reload nginx 2>/dev/null \
           && echo -e "  ${G}✅ nginx${N}" \
           || echo -e "  ${R}❌ nginx (проверьте nginx -t)${N}"
         echo -e "\n  ${G}✅ Перезапуск завершён${N}"; sleep 2 ;;
      6) _change_dc ;;
      7) bash "$HIDE_DIR/bin/watchdog.sh" \
           && echo -e "\n  ${G}✅ Watchdog выполнен${N}"; sleep 2 ;;
      0|q) return ;;
    esac
  done
}

_mtg_action() {
  local action=$1; load_cfg; load_arrays

  # Для restart/stop — убиваем процессы напрямую чтобы избежать зависания
  # systemctl stop может висеть минуты если mtg занят множеством SYN-SENT сокетов
  if [[ "$action" == "restart" || "$action" == "stop" ]]; then
    systemctl reset-failed 'hipr-mtg@0' 'hipr-mtg@1' 'hipr-mtg@2' hipr-mtg 2>/dev/null || true
    pkill -9 -x mtg 2>/dev/null || true
    sleep 1
    # Сбрасываем состояние юнитов после kill
    systemctl reset-failed 'hipr-mtg@0' 'hipr-mtg@1' 'hipr-mtg@2' hipr-mtg 2>/dev/null || true
    if [[ "$action" == "stop" ]]; then
      echo -e "  ${G}✅ mtg остановлен${N}"
      return
    fi
    echo -e "  ${DIM}Процессы остановлены, запускаем...${N}"
  fi

  if [[ "${MODE:-single}" == "multi" ]]; then
    for i in "${!SNI_DOMAINS_ARR[@]}"; do
      systemctl start "hipr-mtg@${i}" 2>/dev/null         && echo -e "  ${G}✅ hipr-mtg@${i}${N}" || echo -e "  ${R}❌ hipr-mtg@${i}${N}"
      sleep 1
    done
  else
    systemctl start hipr-mtg 2>/dev/null       && echo -e "  ${G}✅ hipr-mtg${N}" || echo -e "  ${R}❌ hipr-mtg${N}"
  fi
  sleep 1
}

_change_dc() {
  load_cfg; clear; echo -e "\n  ${BOLD}📡 Выберите Telegram DC${N}\n"
  declare -A DC_NAMES=(
    [1]="DC1 Miami:149.154.175.50"
    [2]="DC2 Amsterdam:149.154.167.51"
    [3]="DC3 Miami:149.154.175.100"
    [4]="DC4 Amsterdam:149.154.167.91"
    [5]="DC5 Singapore:91.108.56.130"
  )
  for k in 1 2 3 4 5; do
    local entry="${DC_NAMES[$k]}"
    local name="${entry%%:*}" ip="${entry##*:}"
    local mark=""; [[ "$ip" == "${ACTIVE_DC:-}" ]] && mark=" ${Y}◀ текущий${N}"
    printf "  ${C}[%d]${N} %-22s %s%b\n" "$k" "$name" "$ip" "$mark"
  done
  echo ""; read -rp "  DC [1-5]: " dc
  local entry="${DC_NAMES[$dc]:-}"
  if [[ -n "$entry" ]]; then
    local ip="${entry##*:}"
    sed -i "s/ACTIVE_DC=.*/ACTIVE_DC=\"$ip\"/" "$CONFIG_FILE"
    _mtg_action restart
    echo -e "\n  ${G}✅ Переключено на $ip${N}"
  fi
  sleep 2
}

