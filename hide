_change_sni_single() {
  load_cfg; load_arrays; clear
  echo -e "\n  ${BOLD}🔑 Смена SNI домена${N}\n"
  echo -e "  ${DIM}Текущий SNI: ${C}${SNI_DOMAINS_ARR[0]:-?}${N}\n"
  echo -e "  ${W}Выберите новый SNI домен:${N}\n"
  echo -e "  ${C}[1]${N}  microsoft.com   ${DIM}(рекомендуется)${N}"
  echo -e "  ${C}[2]${N}  avito.ru        ${DIM}(российский)${N}"
  echo -e "  ${C}[3]${N}  ozon.ru         ${DIM}(российский)${N}"
  echo -e "  ${C}[4]${N}  wildberries.ru  ${DIM}(российский)${N}"
  echo -e "  ${C}[5]${N}  sberbank.ru     ${DIM}(российский, надёжный)${N}"
  echo -e "  ${C}[6]${N}  Свой домен"
  echo ""
  read -rp "  Выбор [1-6]: " ch

  local new_sni
  case "$ch" in
    1) new_sni="microsoft.com" ;;
    2) new_sni="avito.ru" ;;
    3) new_sni="ozon.ru" ;;
    4) new_sni="wildberries.ru" ;;
    5) new_sni="sberbank.ru" ;;
    6) read -rp "  Введите домен: " new_sni; [[ -z "$new_sni" ]] && return ;;
    *) return ;;
  esac

  echo ""
  info_msg "Генерируем новый секрет для $new_sni..."

  local new_secret
  new_secret=$("$MTG_BIN" generate-secret --hex "$new_sni" 2>/dev/null | tr -d '\n')
  if [[ -z "$new_secret" ]]; then
    local rh; rh=$(openssl rand -hex 16)
    local dh; dh=$(echo -n "$new_sni" | xxd -p | tr -d '\n')
    new_secret="ee${rh}${dh}"
  fi

  sed -i "s|SNI_DOMAINS=.*|SNI_DOMAINS=\"$new_sni\"|" "$CONFIG_FILE"
  sed -i "s|MTG_SECRETS=.*|MTG_SECRETS=\"$new_secret\"|" "$CONFIG_FILE"
  sed -i "s|MTG_SECRET=.*|MTG_SECRET=\"$new_secret\"|" "$CONFIG_FILE"
  sed -i "s|^secret = .*|secret = \"$new_secret\"|" "$HIDE_DIR/config/mtg0.toml"

  python3 - "$HIDE_DIR/config/mtg0.toml" "$new_sni" << 'PYEOF' 2>/dev/null || true
import sys, re
path, sni = sys.argv[1], sys.argv[2]
content = open(path).read()
content = re.sub(
  r'\[defense\.doppelganger\]\nurls = \[.*?\]',
  f'[defense.doppelganger]\nurls = [\n  "https://{sni}/",\n  "https://{sni}"\n]',
  content, flags=re.DOTALL
)
open(path, 'w').write(content)
PYEOF

  cat > /etc/nginx/snippets/hipr-stream.conf << EOF
stream {
    map \$ssl_preread_server_name \$hipr_backend {
        $new_sni   127.0.0.1:${MTG_PORTS_ARR[0]:-2398};
        default    127.0.0.1:8443;
    }
    server {
        listen 443;
        listen [::]:443;
        proxy_pass            \$hipr_backend;
        ssl_preread           on;
        proxy_timeout         10m;
        proxy_connect_timeout 10s;
    }
}
EOF

  nginx -t 2>/dev/null && systemctl reload nginx
  systemctl restart hipr-mtg 2>/dev/null
  sleep 2

  local new_link="tg://proxy?server=${DOMAIN}&port=443&secret=${new_secret}"
  echo ""
  echo -e "  ${G}✅ SNI изменён на: ${BOLD}$new_sni${N}"
  echo -e "  ${BOLD}🔗 Новая ссылка:${N}"
  echo ""
  echo -e "  ${C}${new_link}${N}"
  echo ""

  if [[ -n "${BOT_TOKEN:-}" && -n "${BOT_CHAT_ID:-}" ]]; then
    read -rp "  Отправить новую ссылку в бот? [Y/n]: " send_bot
    if [[ "${send_bot,,}" != "n" ]]; then
      local msg="🔑 <b>SNI изменён</b>%0A%0ASNI: <code>$new_sni</code>%0A%0A🔗 Новая ссылка:%0A<code>${new_link}</code>"
      curl -s --max-time 10 \
        "https://api.telegram.org/bot${BOT_TOKEN}/sendMessage" \
        -d "chat_id=${BOT_CHAT_ID}&text=${msg}&parse_mode=HTML" > /dev/null 2>&1 \
        && echo -e "  ${G}✅ Ссылка отправлена в бот${N}" \
        || echo -e "  ${R}❌ Ошибка отправки${N}"
    fi
  fi
  pause
}

_manage_multi_fronting() {
  load_arrays
  while true; do
    clear; echo ""
    echo -e "  ${BOLD}🔀 Multi-fronting управление${N}\n"

    for i in "${!SNI_DOMAINS_ARR[@]}"; do
      local sni="${SNI_DOMAINS_ARR[$i]}"
      local secret="${MTG_SECRETS_ARR[$i]:-?}"
      local port="${MTG_PORTS_ARR[$i]:-?}"
      local svc; svc=$(mtg_svc $i)
      local icon; systemctl is-active --quiet "$svc" 2>/dev/null && icon="🟢" || icon="🔴"
      printf "  %s ${C}[%d]${N} %-22s ${DIM}порт:${N} %-6s ${DIM}секрет:${N} %s...\n" \
        "$icon" "$((i+1))" "$sni" "$port" "${secret:0:16}"
    done

    echo ""
    echo -e "  ${C}[s]${N}  ✏️   Сменить SNI конкретного инстанса"
    echo -e "  ${C}[a]${N}  ➕  Добавить инстанс"
    echo -e "  ${C}[d]${N}  ➖  Удалить инстанс"
    echo -e "  ${C}[r]${N}  🔄  Ротация всех SNI сразу"
    echo -e "  ${C}[l]${N}  🔗  Показать все ссылки"
    echo ""
    echo -e "  ${R}[0]${N}  ← Назад"
    echo ""
    read -rp "  Выбор: " ch
    case "$ch" in
      s|S) _mf_change_sni ;;
      a|A) _mf_add_instance ;;
      d|D) _mf_remove_instance ;;
      r|R) _mf_rotate_all ;;
      l|L) _mf_show_links ;;
      0|q) return ;;
      *) echo -e "\n  ${R}Неверный выбор${N}"; sleep 1 ;;
    esac
    load_arrays
  done
}

_mf_show_links() {
  load_arrays; clear; echo -e "\n  ${BOLD}🔗 Все ссылки Multi-fronting${N}\n"
  for i in "${!SNI_DOMAINS_ARR[@]}"; do
    local sni="${SNI_DOMAINS_ARR[$i]}"
    local secret="${MTG_SECRETS_ARR[$i]}"
    local tg="tg://proxy?server=${DOMAIN}&port=443&secret=${secret}"
    echo -e "  ${BOLD}[$((i+1))] ${C}$sni${N}"
    echo -e "  ${C}${tg}${N}\n"
  done
  pause
}

_mf_change_sni() {
  load_arrays
  echo ""
  echo -e "  Какой инстанс менять? (1-${#SNI_DOMAINS_ARR[@]})"
  read -rp "  Номер: " num
  [[ ! "$num" =~ ^[0-9]+$ ]] && return
  local idx=$((num-1))
  [[ $idx -lt 0 || $idx -ge ${#SNI_DOMAINS_ARR[@]} ]] && { echo -e "  ${R}Нет такого${N}"; sleep 1; return; }

  local old_sni="${SNI_DOMAINS_ARR[$idx]}"
  echo -e "\n  ${DIM}Текущий SNI: ${C}$old_sni${N}\n"
  echo -e "  ${C}[1]${N}  microsoft.com"
  echo -e "  ${C}[2]${N}  avito.ru"
  echo -e "  ${C}[3]${N}  ozon.ru"
  echo -e "  ${C}[4]${N}  wildberries.ru"
  echo -e "  ${C}[5]${N}  sberbank.ru"
  echo -e "  ${C}[6]${N}  Свой домен"
  echo ""
  read -rp "  Выбор: " ch

  local new_sni
  case "$ch" in
    1) new_sni="microsoft.com" ;;
    2) new_sni="avito.ru" ;;
    3) new_sni="ozon.ru" ;;
    4) new_sni="wildberries.ru" ;;
    5) new_sni="sberbank.ru" ;;
    6) read -rp "  Домен: " new_sni; [[ -z "$new_sni" ]] && return ;;
    *) return ;;
  esac

  _apply_sni_change "$idx" "$new_sni"
}

_apply_sni_change() {
  local idx=$1 new_sni=$2
  load_arrays

  info_msg "Генерируем секрет для $new_sni..."
  local new_secret
  new_secret=$("$MTG_BIN" generate-secret --hex "$new_sni" 2>/dev/null | tr -d '\n')
  if [[ -z "$new_secret" ]]; then
    local rh; rh=$(openssl rand -hex 16)
    local dh; dh=$(echo -n "$new_sni" | xxd -p | tr -d '\n')
    new_secret="ee${rh}${dh}"
  fi

  SNI_DOMAINS_ARR[$idx]="$new_sni"
  MTG_SECRETS_ARR[$idx]="$new_secret"

  local new_sni_str; new_sni_str=$(IFS='|'; echo "${SNI_DOMAINS_ARR[*]}")
  local new_sec_str; new_sec_str=$(IFS='|'; echo "${MTG_SECRETS_ARR[*]}")
  sed -i "s|SNI_DOMAINS=.*|SNI_DOMAINS=\"$new_sni_str\"|" "$CONFIG_FILE"
  sed -i "s|MTG_SECRETS=.*|MTG_SECRETS=\"$new_sec_str\"|" "$CONFIG_FILE"
  sed -i "s|MTG_SECRET=.*|MTG_SECRET=\"${MTG_SECRETS_ARR[0]}\"|" "$CONFIG_FILE"

  sed -i "s|^secret = .*|secret = \"$new_secret\"|" "$HIDE_DIR/config/mtg${idx}.toml"
  python3 - "$HIDE_DIR/config/mtg${idx}.toml" "$new_sni" << 'PYEOF' 2>/dev/null || true
import sys, re
path, sni = sys.argv[1], sys.argv[2]
content = open(path).read()
content = re.sub(
  r'\[defense\.doppelganger\]\nurls = \[.*?\]',
  f'[defense.doppelganger]\nurls = [\n  "https://{sni}/",\n  "https://{sni}"\n]',
  content, flags=re.DOTALL
)
open(path, 'w').write(content)
PYEOF

  _rebuild_nginx_stream

  local svc; svc=$(mtg_svc $idx)
  systemctl restart "$svc" 2>/dev/null
  sleep 2

  local new_link="tg://proxy?server=${DOMAIN}&port=443&secret=${new_secret}"
  echo ""
  echo -e "  ${G}✅ Инстанс $((idx+1)) SNI → ${BOLD}$new_sni${N}"
  echo -e "  ${BOLD}🔗 Ссылка:${N}"
  echo -e "  ${C}${new_link}${N}"
  echo ""

  if [[ -n "${BOT_TOKEN:-}" && -n "${BOT_CHAT_ID:-}" ]]; then
    read -rp "  Отправить новую ссылку в бот? [Y/n]: " sb
    if [[ "${sb,,}" != "n" ]]; then
      local msg="🔑 <b>Multi-fronting: SNI[$((idx+1))] изменён</b>%0A%0ASNI: <code>$new_sni</code>%0A%0A🔗 Новая ссылка:%0A<code>${new_link}</code>"
      curl -s --max-time 10 "https://api.telegram.org/bot${BOT_TOKEN}/sendMessage" \
        -d "chat_id=${BOT_CHAT_ID}&text=${msg}&parse_mode=HTML" > /dev/null 2>&1 \
        && echo -e "  ${G}✅ Отправлено${N}" || echo -e "  ${R}❌ Ошибка${N}"
    fi
  fi
  pause
}

_mf_rotate_all() {
  load_arrays
  echo -e "\n  ${Y}⚠️  Все SNI домены будут сменены. Все старые ссылки перестанут работать!${N}"
  read -rp "  Продолжить? [y/N]: " c
  [[ "${c,,}" != "y" ]] && return

  local PRESET=("microsoft.com" "avito.ru" "ozon.ru" "wildberries.ru" "sberbank.ru")
  info_msg "Ротация SNI доменов..."

  for i in "${!SNI_DOMAINS_ARR[@]}"; do
    local new_sni="${PRESET[$((i % ${#PRESET[@]}))]}"
    _apply_sni_change_silent "$i" "$new_sni"
  done

  _rebuild_nginx_stream
  _mtg_action restart
  sleep 2

  echo -e "\n  ${G}✅ Ротация завершена. Новые ссылки:${N}\n"
  _mf_show_links
}

_apply_sni_change_silent() {
  local idx=$1 new_sni=$2
