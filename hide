# 7. ОБНОВЛЕНИЕ
# ══════════════════════════════════════════════════════════════════════════
menu_update() {
  clear; echo ""
  top_b
  printf "${B}  ║${N}  ${BOLD}🔄 %-53s${N}${B}║${N}\n" "Обновление"
  bot_b; echo ""
  echo -e "  ${C}[1]${N}  ⚡  Обновить mtg до последней версии"
  echo -e "  ${C}[2]${N}  🔄  Обновить hide"
  echo -e "  ${C}[3]${N}  🔄  Обновить dnsproxy"
  echo -e "  ${C}[4]${N}  📦  Обновить пакеты системы"
  echo -e "  ${C}[5]${N}  ℹ️   Версии компонентов"
  echo ""; echo -e "  ${R}[0]${N}  ← Назад"; echo ""
  read -rp "  Выберите: " ch
  case "$ch" in
    1)
      echo -e "\n  ${Y}⚡ Обновляем mtg...${N}"
      local latest; latest=$(curl -sf --max-time 10 \
        "https://api.github.com/repos/9seconds/mtg/releases/latest" \
        | python3 -c "import sys,json; print(json.load(sys.stdin)['tag_name'].lstrip('v'))" \
        2>/dev/null || echo "")
      if [[ -n "$latest" ]]; then
        local arch; arch=$(uname -m)
        case "$arch" in x86_64) ma="amd64" ;; aarch64) ma="arm64" ;; *) ma="amd64" ;; esac
        wget -q "https://github.com/9seconds/mtg/releases/download/v${latest}/mtg-${latest}-linux-${ma}.tar.gz" \
          -O /tmp/mtg_new.tar.gz 2>/dev/null && {
          mkdir -p /tmp/mtg-upd
          tar -xzf /tmp/mtg_new.tar.gz -C /tmp/mtg-upd/
          find /tmp/mtg-upd -name "mtg" -type f | head -1 | xargs -I{} cp {} "$MTG_BIN"
          chmod +x "$MTG_BIN"
          rm -rf /tmp/mtg_new.tar.gz /tmp/mtg-upd
          _mtg_action restart
          echo -e "  ${G}✅ mtg обновлён до v$latest${N}"
        } || echo -e "  ${R}❌ Ошибка загрузки${N}"
      else
        echo -e "  ${Y}⚠️  Не удалось получить версию${N}"
      fi
      sleep 2 ;;
    2)
      echo -e "\n  ${Y}🔄 Обновляем hide...${N}"
      curl -fsSL "https://raw.githubusercontent.com/ChernOvOne/HIPR/main/hide" \
        -o "$HIDE_BIN" && chmod +x "$HIDE_BIN" && \
        echo -e "  ${G}✅ hide обновлён${N}" || echo -e "  ${R}❌ Ошибка${N}"
      sleep 2 ;;
    3)
      echo -e "\n  ${Y}🔄 Обновляем dnsproxy...${N}"
      local dlatest; dlatest=$(curl -sf --max-time 10 \
        "https://api.github.com/repos/AdguardTeam/dnsproxy/releases/latest" \
        | python3 -c "import sys,json; print(json.load(sys.stdin)['tag_name'].lstrip('v'))" \
        2>/dev/null || echo "")
      if [[ -n "$dlatest" ]]; then
        local arch; arch=$(uname -m)
        case "$arch" in x86_64) da="linux-amd64" ;; aarch64) da="linux-arm64" ;; *) da="linux-amd64" ;; esac
        wget -q "https://github.com/AdguardTeam/dnsproxy/releases/download/v${dlatest}/dnsproxy-${da}-v${dlatest}.tar.gz" \
          -O /tmp/dns_new.tar.gz 2>/dev/null && {
          mkdir -p /tmp/dns-upd
          tar -xzf /tmp/dns_new.tar.gz -C /tmp/dns-upd/
          find /tmp/dns-upd -name "dnsproxy" -type f | head -1 | xargs -I{} cp {} /usr/local/bin/dnsproxy
          chmod +x /usr/local/bin/dnsproxy
          rm -rf /tmp/dns_new.tar.gz /tmp/dns-upd
          systemctl restart dnsproxy
          echo -e "  ${G}✅ dnsproxy обновлён до v$dlatest${N}"
        } || echo -e "  ${R}❌ Ошибка${N}"
      fi
      sleep 2 ;;
    4) apt-get update -qq && apt-get upgrade -y -qq 2>&1 | tail -5; sleep 2 ;;
    5)
      clear; echo ""
      printf "  %-22s %s\n" "HIPR:" "$VERSION"
      printf "  %-22s %s\n" "mtg:" "$($MTG_BIN --version 2>/dev/null | head -1 || echo '—')"
      printf "  %-22s %s\n" "dnsproxy:" "$(dnsproxy --version 2>&1 | head -1 || echo '—')"
      printf "  %-22s %s\n" "nginx:" "$(nginx -v 2>&1 | grep -o '[0-9.]*' | head -1)"
      printf "  %-22s %s\n" "certbot:" "$(certbot --version 2>/dev/null | head -1 || echo '—')"
      printf "  %-22s %s\n" "OpenSSL:" "$(openssl version | awk '{print $2}')"
      [[ -x /usr/local/bin/prometheus ]] && \
        printf "  %-22s %s\n" "Prometheus:" "$(prometheus --version 2>&1 | head -1 || echo '—')"
      [[ -f /etc/grafana/grafana.ini ]] && \
        printf "  %-22s %s\n" "Grafana:" "$(grafana-server --version 2>/dev/null || echo 'установлена')"
      # BBR версия
      local kver; kver=$(uname -r | grep -oP '^\d+\.\d+' | head -1)
      local kmaj; kmaj=$(echo "$kver" | cut -d. -f1)
      local kmin; kmin=$(echo "$kver" | cut -d. -f2)
      local cur_cc; cur_cc=$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null || echo '—')
      local bbr_ver="—"
      if [[ "$cur_cc" == "bbr" ]]; then
        if (( kmaj > 6 )) || (( kmaj == 6 && kmin >= 3 )); then
          bbr_ver="BBRv3 (ядро $kver)"
        elif (( kmaj > 5 )) || (( kmaj == 5 && kmin >= 18 )); then
          bbr_ver="BBR ≈v2/v3 (ядро $kver)"
        else
          bbr_ver="BBRv1 (ядро $kver)"
        fi
      else
        bbr_ver="$cur_cc (ядро $kver)"
      fi
      printf "  %-22s %s\n" "TCP CC:" "$bbr_ver"
      echo ""; pause ;;
    0|q) return ;;
  esac
}

# ══════════════════════════════════════════════════════════════════════════
# 8. ОПТИМИЗАЦИЯ СЕРВЕРА
# ══════════════════════════════════════════════════════════════════════════
menu_optimize() {
  while true; do
    clear; echo ""
    top_b
    printf "${B}  ║${N}  ${BOLD}🚀 %-53s${N}${B}║${N}\n" "Оптимизация сервера"
    sep

    local bbr_status congestion kshort kmaj kmin
    congestion=$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null || echo "unknown")
    kshort=$(uname -r | grep -oP '^\d+\.\d+' | head -1)
    kmaj=$(echo "$kshort" | cut -d. -f1)
    kmin=$(echo "$kshort" | cut -d. -f2)
    if [[ "$congestion" == "bbr" ]]; then
      if (( kmaj > 6 )) || (( kmaj == 6 && kmin >= 3 )); then
        bbr_status="${G}✅ BBRv3 (ядро $kshort)${N}"
      elif (( kmaj > 5 )) || (( kmaj == 5 && kmin >= 18 )); then
        bbr_status="${Y}✅ BBR ≈v2/v3 (ядро $kshort)${N}"
      else
        bbr_status="${Y}✅ BBRv1 (ядро $kshort) — BBRv3 лучше${N}"
      fi
    else
      bbr_status="${R}❌ выключен ($congestion)${N}"
    fi
    printf "${B}  ║${N}  ${DIM}%-16s${N} %-39b${B}║${N}\n" "BBR:" "$bbr_status"

    local ulimit_val; ulimit_val=$(ulimit -n 2>/dev/null || echo "?")
    kv "Файл. дескрипт.:" "$ulimit_val"
    local somaxconn; somaxconn=$(sysctl -n net.core.somaxconn 2>/dev/null || echo "?")
    kv "somaxconn:" "$somaxconn"
    bot_b; echo ""

    echo -e "  ${C}[1]${N}  🚀  Включить BBR"
    echo -e "  ${C}[2]${N}  ⚡  Применить оптимизации sysctl (100+ юзеров)"
    echo -e "  ${C}[3]${N}  📊  Показать текущие параметры сети"
    echo -e "  ${C}[4]${N}  🔄  Сбросить к дефолтным настройкам"
    echo ""; echo -e "  ${R}[0]${N}  ← Назад"; echo ""
    read -rp "  Выберите: " ch
    case "$ch" in
      1) _enable_bbr ;;
      2) _apply_sysctl ;;
      3) _show_network_params ;;
      4) _reset_sysctl ;;
      0|q) return ;;
    esac
  done
}

_enable_bbr() {
  echo ""
  # Определяем версию ядра и что реально доступно
  local kver; kver=$(uname -r | grep -oP '^\d+\.\d+' | head -1)
  local kmaj; kmaj=$(echo "$kver" | cut -d. -f1)
  local kmin; kmin=$(echo "$kver" | cut -d. -f2)
  local avail; avail=$(sysctl -n net.ipv4.tcp_available_congestion_control 2>/dev/null || echo "")
  local current; current=$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null || echo "")

  # Определяем какой BBR фактически будет использован
  local bbr_label=""
  if (( kmaj > 6 )) || (( kmaj == 6 && kmin >= 3 )); then
    bbr_label="BBRv3"
  elif (( kmaj > 5 )) || (( kmaj == 5 && kmin >= 18 )); then
    bbr_label="BBR (≈v2/v3 draft, ядро $kver)"
  else
    bbr_label="BBRv1 (ядро $kver)"
  fi

  if [[ "$current" == "bbr" ]]; then
    echo -e "  ${G}✅ $bbr_label уже активен${N}"
    echo -e "  ${DIM}Ядро: $kver  |  Алгоритм: bbr${N}"
    pause; return
  fi

  if ! echo "$avail" | grep -qw "bbr"; then
    modprobe tcp_bbr 2>/dev/null || true
    avail=$(sysctl -n net.ipv4.tcp_available_congestion_control 2>/dev/null || echo "")
  fi

  if echo "$avail" | grep -qw "bbr"; then
    # Перезаписываем файл целиком чтобы не дублировать строки
    {
      grep -v 'default_qdisc\|tcp_congestion_control' /etc/sysctl.d/99-hipr.conf 2>/dev/null || true
      echo "net.core.default_qdisc = fq"
      echo "net.ipv4.tcp_congestion_control = bbr"
    } > /tmp/sysctl-hipr.tmp && mv /tmp/sysctl-hipr.tmp /etc/sysctl.d/99-hipr.conf
    sysctl -p /etc/sysctl.d/99-hipr.conf > /dev/null 2>&1
    local check; check=$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)
    if [[ "$check" == "bbr" ]]; then
      echo -e "  ${G}✅ $bbr_label включён${N}"
      echo -e "  ${DIM}Ядро: $kver${N}"
      if (( kmaj < 6 )) || (( kmaj == 6 && kmin < 3 )); then
        echo ""
        echo -e "  ${DIM}💡 Для BBRv3 нужно ядро 6.3+${N}"
        echo -e "  ${DIM}   Ubuntu 24.04 HWE: apt install linux-generic-hwe-24.04${N}"
      fi
    else
      echo -e "  ${R}❌ Не удалось активировать${N}"
    fi
  else
    echo -e "  ${Y}⚠️  BBR не скомпилирован в ядро $kver${N}"
    echo -e "  ${DIM}Нужен Linux 4.9+. Для BBRv3: ядро 6.3+${N}"
    echo -e "  ${DIM}Ubuntu 24.04 HWE: apt install linux-generic-hwe-24.04${N}"
  fi
  pause
}

_apply_sysctl() {
  echo ""
  cat > /etc/sysctl.d/99-hipr.conf << 'SYSCTL'
# HIPR — оптимизации для 100+ пользователей
net.core.default_qdisc = fq
net.ipv4.tcp_congestion_control = bbr
net.core.rmem_max = 16777216
net.core.wmem_max = 16777216
net.ipv4.tcp_rmem = 4096 87380 16777216
net.ipv4.tcp_wmem = 4096 65536 16777216
net.core.somaxconn = 65535
net.core.netdev_max_backlog = 65535
net.ipv4.tcp_max_syn_backlog = 65535
net.ipv4.tcp_tw_reuse = 1
net.ipv4.tcp_fin_timeout = 15
fs.file-max = 1000000
SYSCTL
  sysctl -p /etc/sysctl.d/99-hipr.conf > /dev/null 2>&1 \
    && echo -e "  ${G}✅ sysctl оптимизирован${N}" \
    || echo -e "  ${Y}⚠️  Частично применено${N}"
  pause
}

_show_network_params() {
  clear; echo -e "\n  ${BOLD}📊 Параметры сети${N}\n"
  local kver; kver=$(uname -r)
  local kshort; kshort=$(echo "$kver" | grep -oP '^\d+\.\d+' | head -1)
  local kmaj; kmaj=$(echo "$kshort" | cut -d. -f1)
  local kmin; kmin=$(echo "$kshort" | cut -d. -f2)
  local cur_cc; cur_cc=$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null || echo '—')
  local avail_cc; avail_cc=$(sysctl -n net.ipv4.tcp_available_congestion_control 2>/dev/null || echo '—')

  printf "  ${DIM}%-42s${N} ${Y}%s${N}\n" "Ядро Linux:" "$kver"

  local bbr_info=""
  if [[ "$cur_cc" == "bbr" ]]; then
    if (( kmaj > 6 )) || (( kmaj == 6 && kmin >= 3 )); then
      bbr_info="${G}bbr (BBRv3 — оптимально!)${N}"
    elif (( kmaj > 5 )) || (( kmaj == 5 && kmin >= 18 )); then
      bbr_info="${Y}bbr (≈ BBRv2/v3 draft)${N}"
    else
      bbr_info="${Y}bbr (BBRv1 — работает, но BBRv3 лучше)${N}"
    fi
  else
    bbr_info="${R}$cur_cc (BBR не активен)${N}"
  fi
  printf "  ${DIM}%-42s${N} %b\n" "TCP congestion control:" "$bbr_info"
  printf "  ${DIM}%-42s${N} ${DIM}%s${N}\n" "Доступные алгоритмы:" "$avail_cc"

  if [[ "$cur_cc" != "bbr" ]] || { (( kmaj < 6 )) || (( kmaj == 6 && kmin < 3 )); }; then
    echo ""
    if [[ "$cur_cc" != "bbr" ]]; then
      echo -e "  ${Y}💡 BBR выключен.${N} Включить: hide → [8] Оптимизация → [1]"
    elif (( kmaj < 6 )) || (( kmaj == 6 && kmin < 3 )); then
      echo -e "  ${Y}💡 BBRv3 требует ядро 6.3+${N} (сейчас $kshort)"
      echo -e "  ${DIM}   Ubuntu 24.04 HWE: apt install linux-generic-hwe-24.04${N}"
    fi
  fi

  echo ""
  local params=(
    "net.core.somaxconn"
    "net.core.rmem_max"
    "net.core.wmem_max"
    "net.ipv4.tcp_tw_reuse"
    "net.ipv4.tcp_fin_timeout"
    "fs.file-max"
  )
  for p in "${params[@]}"; do
    local val; val=$(sysctl -n "$p" 2>/dev/null || echo "—")
    printf "  ${DIM}%-42s${N} ${Y}%s${N}\n" "$p" "$val"
  done
  echo ""; pause
}

_reset_sysctl() {
  read -rp "  Сбросить настройки sysctl? [y/N]: " c
  [[ "${c,,}" != "y" ]] && return
  rm -f /etc/sysctl.d/99-hipr.conf
  echo -e "  ${G}✅ Файл удалён. Перезагрузите сервер для применения${N}"
  pause
}

# ══════════════════════════════════════════════════════════════════════════
# 9. УДАЛЕНИЕ / ПЕРЕУСТАНОВКА
# ══════════════════════════════════════════════════════════════════════════
menu_uninstall() {
  clear; echo ""
  echo -e "${R}${BOLD}  ╔══════════════════════════════════════════════════════════╗${N}"
  echo -e "${R}${BOLD}  ║   ⚠️   УДАЛЕНИЕ / ПЕРЕУСТАНОВКА HIPR                    ║${N}"
  echo -e "${R}${BOLD}  ╚══════════════════════════════════════════════════════════╝${N}"
  echo ""
  echo -e "  ${C}[1]${N}  🔄  Переустановить"
  echo -e "  ${C}[2]${N}  🗑️   Полностью удалить"
  echo ""
  echo -e "  ${R}[0]${N}  ← Назад"
  echo ""
  read -rp "  Выберите: " ch
  case "$ch" in
    1) _reinstall ;;
    2) _full_uninstall ;;
    0|q) return ;;
  esac
}

_reinstall() {
  echo ""
  echo -e "  ${Y}⚠️  Будет запущен install.sh — текущая установка будет пересоздана${N}"
  read -rp "  Продолжить? [y/N]: " c
  [[ "${c,,}" != "y" ]] && return
  local url="https://raw.githubusercontent.com/ChernOvOne/HIPR/main/install.sh"
  if curl -sf --max-time 5 "$url" > /dev/null 2>&1; then
    bash <(curl -fsSL "$url")
  else
    echo -e "\n  ${R}❌ GitHub недоступен. Скачайте install.sh вручную${N}"
    sleep 3
  fi
}

_full_uninstall() {
  clear; echo ""
  echo -e "  ${R}${BOLD}⚠️  ПОЛНОЕ УДАЛЕНИЕ HIPR${N}\n"
  echo -e "  Будет удалено: все сервисы, /opt/hipr, /var/www/hipr, /usr/local/bin/hide"
  echo -e "  ${G}Останется:${N} nginx, certbot, сертификаты"
  echo ""
  read -rp "  💾 Сохранить бэкап? [Y/n]: " do_bak
  if [[ "${do_bak,,}" != "n" ]]; then
    local bak="/root/hipr_backup_$(date +%Y%m%d_%H%M%S)"
    mkdir -p "$bak"
    [[ -f "$CONFIG_FILE" ]]              && cp "$CONFIG_FILE" "$bak/"
    [[ -d "$HIDE_DIR/config" ]]          && cp -r "$HIDE_DIR/config" "$bak/"
    [[ -d "$HIDE_DIR/themes/custom" ]]   && cp -r "$HIDE_DIR/themes/custom" "$bak/" 2>/dev/null || true
    cp -r /etc/letsencrypt/live "$bak/letsencrypt" 2>/dev/null || true
    echo -e "  ${G}💾 Бэкап: $bak${N}\n"
  fi
  read -rp "  Введите 'DELETE' для подтверждения: " confirm
  [[ "$confirm" != "DELETE" ]] && { echo -e "\n  Отменено."; sleep 2; return; }
  echo -e "\n  ${Y}🗑️  Удаляем...${N}\n"

  load_cfg; load_arrays
  if [[ "${MODE:-single}" == "multi" ]]; then
    for i in "${!SNI_DOMAINS_ARR[@]}"; do
      systemctl stop "hipr-mtg@${i}" 2>/dev/null || true
      systemctl disable "hipr-mtg@${i}" 2>/dev/null || true
    done
    rm -f /etc/systemd/system/hipr-mtg@.service
  else
    systemctl stop hipr-mtg 2>/dev/null || true
    systemctl disable hipr-mtg 2>/dev/null || true
    rm -f /etc/systemd/system/hipr-mtg.service
  fi

  systemctl stop hipr-watchdog.timer dnsproxy prometheus grafana-server 2>/dev/null || true
  systemctl disable hipr-watchdog.timer hipr-watchdog dnsproxy prometheus grafana-server 2>/dev/null || true
  rm -f /etc/systemd/system/hipr-watchdog.{service,timer}
  rm -f /etc/systemd/system/dnsproxy.service
  rm -f /etc/systemd/system/prometheus.service
  systemctl daemon-reload
  echo -e "  ${G}✓${N} Сервисы"

  rm -f /etc/nginx/sites-{enabled,available}/hipr-{http,ssl,fallback,grafana}
  rm -f /etc/nginx/snippets/hipr-stream.conf
  rm -f /etc/nginx/modules-enabled/60-mod-hipr-stream.conf
  rm -f /etc/nginx/conf.d/hipr-logformat.conf
  sed -i '/hipr-stream\.conf/d' /etc/nginx/nginx.conf 2>/dev/null || true
  nginx -t 2>/dev/null && systemctl reload nginx 2>/dev/null || true
  echo -e "  ${G}✓${N} nginx"

  rm -rf /opt/hipr /var/www/hipr /usr/local/bin/hide
  rm -f /usr/local/bin/dnsproxy /usr/local/bin/prometheus /usr/local/bin/promtool
  rm -f /etc/sysctl.d/99-hipr.conf
  rm -f /etc/security/limits.d/hipr.conf
  crontab -l 2>/dev/null | grep -v 'hipr\|certbot\|daily-report' | crontab - 2>/dev/null || true
  killall -9 mtg 2>/dev/null || true
  echo -e "  ${G}✓${N} Файлы"

  echo ""
  echo -e "  ${G}${BOLD}✅ HIPR полностью удалён${N}"
  echo ""
  exit 0
}

# ══════════════════════════════════════════════════════════════════════════
# ТОЧКА ВХОДА
# ══════════════════════════════════════════════════════════════════════════
case "${1:-}" in
  status)
    load_cfg; load_arrays
    for i in "${!SNI_DOMAINS_ARR[@]}"; do
      svc=$(mtg_svc $i)
      echo -e "$(svc_icon $svc)  mtg@${i} (${SNI_DOMAINS_ARR[$i]})"
    done
    echo -e "$(svc_icon nginx)  nginx"
    echo -e "$(svc_icon dnsproxy)  dnsproxy"
    echo -e "$(svc_icon hipr-watchdog.timer)  watchdog"
    echo -e "🌐  ${DOMAIN:-—}"
    echo -e "📡  ${ACTIVE_DC:-—}"
    echo -e "⚙️   ${MODE:-single}" ;;
  links)
    load_arrays
    for i in "${!SNI_DOMAINS_ARR[@]}"; do
      echo "tg://proxy?server=${DOMAIN}&port=443&secret=${MTG_SECRETS_ARR[$i]}"
    done ;;
  link)
    load_arrays
    echo "tg://proxy?server=${DOMAIN}&port=443&secret=${MTG_SECRETS_ARR[0]}" ;;
  logs)
    load_cfg
    tail -f "$HIDE_DIR/logs/mtg0.log" 2>/dev/null ;;
  restart)  _mtg_action restart; systemctl reload nginx 2>/dev/null ;;
  stop)     _mtg_action stop ;;
  start)    _mtg_action start ;;
  theme)    echo "$(active_theme)" ;;
  sni)
    load_arrays
    for i in "${!SNI_DOMAINS_ARR[@]}"; do
      echo "[$((i+1))] ${SNI_DOMAINS_ARR[$i]}"
    done ;;
  watchdog) bash "$HIDE_DIR/bin/watchdog.sh" ;;
  report)   bash "$HIDE_DIR/bin/daily-report.sh" ;;
  uninstall) menu_uninstall ;;
  optimize)  menu_optimize ;;
  help|--help|-h)
    echo -e "\n${BOLD}🛡️  HIPR CLI${N} v${VERSION}\n"
    echo -e "  ${C}hide${N}              — интерактивное меню"
    echo -e "  ${C}hide status${N}       — статус сервисов"
    echo -e "  ${C}hide links${N}        — все ссылки tg://"
    echo -e "  ${C}hide link${N}         — первая ссылка"
    echo -e "  ${C}hide sni${N}          — список SNI доменов"
    echo -e "  ${C}hide logs${N}         — live лог mtg"
    echo -e "  ${C}hide restart${N}      — перезапустить всё"
    echo -e "  ${C}hide watchdog${N}     — запустить watchdog"
    echo -e "  ${C}hide report${N}       — отправить отчёт в бот"
    echo -e "  ${C}hide optimize${N}     — меню оптимизации"
    echo -e "  ${C}hide uninstall${N}    — удалить HIPR"
    echo "" ;;
  "")
    [[ $EUID -ne 0 ]] && echo -e "${Y}⚠️  Рекомендуется sudo${N}\n"
    main_menu ;;
  *) echo -e "${R}❌ Неизвестно: $1${N}  →  hide help" ;;
esac
