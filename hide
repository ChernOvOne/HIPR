_manage_ipv6() {
  clear; echo ""
  top_b
  printf "${B}  ║${N}  ${BOLD}🌐 %-53s${N}${B}║${N}\n" "Управление IPv6"
  sep

  local ipv6_val; ipv6_val=$(sysctl -n net.ipv6.conf.all.disable_ipv6 2>/dev/null || echo "0")
  if [[ "$ipv6_val" == "1" ]]; then
    kv "Статус IPv6:" "🔴 отключён"
  else
    kv "Статус IPv6:" "🟢 включён"
  fi

  local syn_count; syn_count=$(ss -tn state syn-sent 2>/dev/null | grep -c mtg || echo 0)
  kv "SYN-SENT (mtg):" "$syn_count зависших соединений"
  bot_b; echo ""

  echo -e "  ${C}[1]${N}  🔴  Отключить IPv6 ${DIM}(фикс зависших SYN-SENT)${N}"
  echo -e "  ${C}[2]${N}  🟢  Включить IPv6"
  echo ""; echo -e "  ${R}[0]${N}  ← Назад"; echo ""
  read -rp "  Выберите: " ch
  case "$ch" in
    1)
      local iface; iface=$(ip route | grep default | awk '{print $5}' | head -1)
      iface="${iface:-eth0}"
      sysctl -w net.ipv6.conf.all.disable_ipv6=1 > /dev/null 2>&1
      sysctl -w net.ipv6.conf.default.disable_ipv6=1 > /dev/null 2>&1
      sysctl -w "net.ipv6.conf.${iface}.disable_ipv6=1" > /dev/null 2>&1
      # Сохраняем в sysctl.d
      grep -q 'disable_ipv6' /etc/sysctl.d/99-hipr.conf 2>/dev/null || {
        cat >> /etc/sysctl.d/99-hipr.conf << EOF
net.ipv6.conf.all.disable_ipv6 = 1
net.ipv6.conf.default.disable_ipv6 = 1
net.ipv6.conf.${iface}.disable_ipv6 = 1
EOF
      }
      sed -i 's/DISABLE_IPV6=.*/DISABLE_IPV6="true"/' "$CONFIG_FILE" 2>/dev/null ||         echo 'DISABLE_IPV6="true"' >> "$CONFIG_FILE"
      # Перезапускаем mtg
      load_cfg
      if [[ "${MODE:-single}" == "multi" ]]; then
        for i in 0 1 2 3 4; do
          systemctl is-enabled --quiet "hipr-mtg@${i}" 2>/dev/null &&             systemctl restart "hipr-mtg@${i}" 2>/dev/null || true
        done
      else
        systemctl restart hipr-mtg 2>/dev/null || true
      fi
      ok "IPv6 отключён, mtg перезапущен"
      sleep 2
      local new_syn; new_syn=$(ss -tn state syn-sent 2>/dev/null | grep -c mtg || echo 0)
      ok "SYN-SENT после перезапуска: $new_syn"
      pause ;;
    2)
      local iface; iface=$(ip route | grep default | awk '{print $5}' | head -1)
      iface="${iface:-eth0}"
      sysctl -w net.ipv6.conf.all.disable_ipv6=0 > /dev/null 2>&1
      sysctl -w net.ipv6.conf.default.disable_ipv6=0 > /dev/null 2>&1
      sysctl -w "net.ipv6.conf.${iface}.disable_ipv6=0" > /dev/null 2>&1
      sed -i '/disable_ipv6/d' /etc/sysctl.d/99-hipr.conf 2>/dev/null || true
      sed -i 's/DISABLE_IPV6=.*/DISABLE_IPV6="false"/' "$CONFIG_FILE" 2>/dev/null || true
      load_cfg
      if [[ "${MODE:-single}" == "multi" ]]; then
        for i in 0 1 2 3 4; do
          systemctl is-enabled --quiet "hipr-mtg@${i}" 2>/dev/null &&             systemctl restart "hipr-mtg@${i}" 2>/dev/null || true
        done
      else
        systemctl restart hipr-mtg 2>/dev/null || true
      fi
      ok "IPv6 включён, mtg перезапущен"
      pause ;;
    0|q) return ;;
  esac
}


