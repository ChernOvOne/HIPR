}

_change_dc() {
  load_cfg; clear; echo -e "\n  ${BOLD}Выберите Telegram DC:${N}\n"
  declare -A DC_NAMES=(
    [1]="DC1 Miami:149.154.175.50"
    [2]="DC2 Amsterdam:149.154.167.51"
    [3]="DC3 Miami:149.154.175.100"
    [4]="DC4 Amsterdam:149.154.167.91"
    [5]="DC5 Singapore:91.108.56.130"
  )
  for k in 1 2 3 4 5; do
    local entry="${DC_NAMES[$k]}"
    local name="${entry%%:*}" ip="${entry##*:}"
    local mark=""; [[ "$ip" == "${ACTIVE_DC:-}" ]] && mark=" ${G}← текущий${N}"
    [[ "$k" == "2" ]] && mark="$mark ${C}★${N}"
    printf "  ${W}[%d]${N} %-22s %s%b\n" "$k" "$name" "$ip" "$mark"
  done
  echo ""; read -rp "  DC [1-5]: " dc
  local entry="${DC_NAMES[$dc]:-}"
  if [[ -n "$entry" ]]; then
    local ip="${entry##*:}"
    sed -i "s/ACTIVE_DC=.*/ACTIVE_DC=\"$ip\"/" "$CONFIG_FILE"
    systemctl restart hipr-mtg
    echo -e "\n  ${G}✓ Переключено на $ip${N}"
  fi
  sleep 2
}

