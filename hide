_stats_today() {
  clear; echo -e "\n  ${BOLD}📊 Статистика прокси${N}\n"

  local metrics
  metrics=$(curl -sf --max-time 3 http://127.0.0.1:3129/metrics 2>/dev/null)

  if [[ -z "$metrics" ]]; then
    echo -e "  ${R}❌ Prometheus недоступен (127.0.0.1:3129)${N}"
    echo -e "  ${DIM}Проверьте: systemctl status hipr-mtg${N}"
    echo ""; pause; return
  fi

  local active tg_conns fronting replays concurrency
  active=$(echo "$metrics" | grep '^mtg_client_connections{' \
    | awk '{sum+=$2} END{print int(sum)}')
  tg_conns=$(echo "$metrics" | grep '^mtg_telegram_connections{' \
    | awk '{sum+=$2} END{print int(sum)}')
  fronting=$(echo "$metrics" | grep '^mtg_domain_fronting ' \
    | awk '{print int($2)}')
  replays=$(echo "$metrics" | grep '^mtg_replay_attacks ' \
    | awk '{print int($2)}')
  concurrency=$(echo "$metrics" | grep '^mtg_concurrency_limited ' \
    | awk '{print int($2)}')

  # Трафик к Telegram
  local tg_in tg_out front_in front_out
  tg_in=$(echo "$metrics" | grep '^mtg_telegram_traffic{' \
    | grep 'from_client' | awk '{sum+=$2} END{print int(sum)}')
  tg_out=$(echo "$metrics" | grep '^mtg_telegram_traffic{' \
    | grep 'to_client' | awk '{sum+=$2} END{print int(sum)}')
  front_in=$(echo "$metrics" | grep '^mtg_domain_fronting_traffic{' \
    | grep 'from_client' | awk '{sum+=$2} END{print int(sum)}')
  front_out=$(echo "$metrics" | grep '^mtg_domain_fronting_traffic{' \
    | grep 'to_client' | awk '{sum+=$2} END{print int(sum)}')

  fmt_bytes() {
    local b=$1
    if (( b > 1073741824 )); then echo "$(python3 -c "print(f'{$b/1073741824:.1f} GB')")";
    elif (( b > 1048576 )); then echo "$(python3 -c "print(f'{$b/1048576:.1f} MB')")";
    elif (( b > 1024 )); then echo "$(python3 -c "print(f'{$b/1024:.1f} KB')")";
    else echo "${b} B"; fi
  }

  # DC распределение
  local dc_info
  dc_info=$(echo "$metrics" | grep '^mtg_telegram_connections{' \
    | sed 's/mtg_telegram_connections{dc="\([^"]*\)",telegram_ip="\([^"]*\)"} \(.*\)/DC\1 (\2): \3/')

  printf "  🟢  %-30s ${Y}%s${N}\n"  "Активных соединений:"     "${active:-0}"
  printf "  📡  %-30s ${Y}%s${N}\n"  "→ Telegram DC:"           "${tg_conns:-0}"
  printf "  📥  %-30s ${G}%s${N}\n"  "Трафик входящий:"         "$(fmt_bytes ${tg_in:-0})"
  printf "  📤  %-30s ${G}%s${N}\n"  "Трафик исходящий:"        "$(fmt_bytes ${tg_out:-0})"
  printf "  🎭  %-30s ${C}%s${N}\n"  "FakeTLS handshakes:"      "${fronting:-0}"
  printf "  🛡️   %-30s ${R}%s${N}\n" "Replay/probing атак:"     "${replays:-0}"
  printf "  🚫  %-30s ${Y}%s${N}\n"  "Отклонено (лимит):"       "${concurrency:-0}"
  echo ""
  if [[ -n "$dc_info" ]]; then
    echo -e "  ${BOLD}📡 Соединения по DC:${N}"
    while IFS= read -r line; do
      echo -e "  ${DIM}$line${N}"
    done <<< "$dc_info"
    echo ""
  fi
  pause
}

