#!/bin/bash
# ═══════════════════════════════════════════════════════════════════════════
#  HIPR CLI — команда: hide
#  https://github.com/ChernOvOne/HIPR
# ═══════════════════════════════════════════════════════════════════════════

HIDE_DIR="/opt/hipr"
CONFIG_FILE="$HIDE_DIR/config.env"
MTG_BIN="$HIDE_DIR/bin/mtg"
HIDE_BIN="/usr/local/bin/hide"
WEB_DIR="/var/www/hipr"
THEMES_LOCAL="$HIDE_DIR/themes"
THEMES_API="https://api.github.com/repos/ChernOvOne/HIPR/contents/themes"
THEMES_RAW="https://raw.githubusercontent.com/ChernOvOne/HIPR/main/themes"
LOG_MTG="$HIDE_DIR/logs/mtg.log"
LOG_WD="$HIDE_DIR/logs/watchdog.log"
LOG_NGX="$HIDE_DIR/logs/nginx-access.log"
VERSION="3.0"

R='\033[0;31m'; G='\033[0;32m'; Y='\033[1;33m'
B='\033[0;34m'; C='\033[0;36m'; W='\033[1;37m'
N='\033[0m';    BOLD='\033[1m'; DIM='\033[2m'

# ── Утилиты ────────────────────────────────────────────────────────────────
load_cfg()  { [[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE" || true; }
top_b()     { echo -e "${B}  ╔══════════════════════════════════════════════════════════╗${N}"; }
bot_b()     { echo -e "${B}  ╚══════════════════════════════════════════════════════════╝${N}"; }
sep()       { echo -e "${B}  ╠══════════════════════════════════════════════════════════╣${N}"; }
row()       { printf "${B}  ║${N} %-57s${B}║${N}\n" "$1"; }
kv()        { printf "${B}  ║${N}  ${DIM}%-16s${N} ${W}%-39s${N}${B}║${N}\n" "$1" "$2"; }
kvc()       { printf "${B}  ║${N}  ${DIM}%-16s${N} ${C}%-39s${N}${B}║${N}\n" "$1" "$2"; }
pause()     { echo ""; read -rp "  Нажмите Enter для продолжения..." _; }

svc_status() {
  systemctl is-active --quiet "$1" 2>/dev/null \
    && echo -e "${G}🟢 работает${N}" || echo -e "${R}🔴 остановлен${N}"
}
svc_icon() {
  systemctl is-active --quiet "$1" 2>/dev/null && echo "🟢" || echo "🔴"
}

get_stats() {
  local metrics
  metrics=$(curl -sf --max-time 2 http://127.0.0.1:3129/metrics 2>/dev/null)

  if [[ -z "$metrics" ]]; then
    STAT_CONNS="—"; STAT_TODAY="—"; STAT_BYTES="—"
    STAT_ACTIVE="0"; STAT_TG_CONNS="0"; STAT_FRONTING="0"
    return
  fi

  # Активные соединения прямо сейчас
  STAT_ACTIVE=$(echo "$metrics" | grep '^mtg_client_connections{' \
    | awk '{sum+=$2} END{print int(sum)}')

  # Всего domain fronting событий (FakeTLS handshakes)
  STAT_FRONTING=$(echo "$metrics" | grep '^mtg_domain_fronting ' \
    | awk '{print int($2)}')

  # Активных соединений к Telegram
  STAT_TG_CONNS=$(echo "$metrics" | grep '^mtg_telegram_connections{' \
    | awk '{sum+=$2} END{print int(sum)}')

  # Суммарный трафик (from_client + to_client к Telegram)
  local bytes_total
  bytes_total=$(echo "$metrics" | grep '^mtg_telegram_traffic{' \
    | awk '{sum+=$2} END{print int(sum)}')
  local bytes_front
  bytes_front=$(echo "$metrics" | grep '^mtg_domain_fronting_traffic{' \
    | awk '{sum+=$2} END{print int(sum)}')
  local bytes_all=$(( bytes_total + bytes_front ))

  if (( bytes_all > 1073741824 )); then
    STAT_BYTES=$(python3 -c "print(f'{$bytes_all/1073741824:.1f} GB')")
  elif (( bytes_all > 1048576 )); then
    STAT_BYTES=$(python3 -c "print(f'{$bytes_all/1048576:.1f} MB')")
  elif (( bytes_all > 1024 )); then
    STAT_BYTES=$(python3 -c "print(f'{$bytes_all/1024:.1f} KB')")
  else
    STAT_BYTES="${bytes_all} B"
  fi

  # Replay атаки (active probing детект)
  STAT_REPLAYS=$(echo "$metrics" | grep '^mtg_replay_attacks ' \
    | awk '{print int($2)}')

  STAT_CONNS="$STAT_ACTIVE"
  STAT_TODAY="$STAT_TG_CONNS"
}

active_theme() {
  [[ -f "$HIDE_DIR/config/active_theme" ]] && cat "$HIDE_DIR/config/active_theme" || echo "—"
}

# ── Шапка ─────────────────────────────────────────────────────────────────
draw_header() {
  load_cfg; get_stats; clear
  echo -e "${C}${BOLD}"
  echo "   ██╗  ██╗██╗██████╗ ██████╗ "
  echo "   ██║  ██║██║██╔══██╗██╔══██╗"
  echo "   ███████║██║██████╔╝██████╔╝"
  echo "   ██╔══██║██║██╔═══╝ ██╔══██╗"
  echo "   ██║  ██║██║██║     ██║  ██║"
  echo "   ╚═╝  ╚═╝╚═╝╚═╝     ╚═╝  ╚═╝  v${VERSION}"
  echo -e "${N}"
  local mtg_s nginx_s wd_s
  mtg_s=$(svc_icon hipr-mtg)
  nginx_s=$(svc_icon nginx)
  wd_s=$(svc_icon hipr-watchdog.timer 2>/dev/null)
  top_b
  printf "${B}  ║${N}  %s %-13s %s %-13s %s %-18s${B}║${N}\n" \
    "$mtg_s" "hipr-mtg" "$nginx_s" "nginx" "$wd_s" "watchdog"
  sep
  kv  "🌐 Домен:"   "${DOMAIN:-не задан}"
  kvc "📡 DC:"       "${ACTIVE_DC:-—}"
  kv  "🎨 Тема:"    "$(active_theme)"
  sep
  printf "${B}  ║${N}  📊  ${DIM}Активных${N}  ${Y}%-4s${N}  ${DIM}→ Telegram${N}  ${Y}%-4s${N}  ${DIM}Трафик${N}  ${Y}%-8s${N}  ${DIM}Probing${N}  ${Y}%-4s${N}${B}║${N}\n" \
    "$STAT_ACTIVE" "$STAT_TG_CONNS" "$STAT_BYTES" "${STAT_REPLAYS:-0}"
  row ""; bot_b; echo ""
}

# ══════════════════════════════════════════════════════════════════════════
# ГЛАВНОЕ МЕНЮ
# ══════════════════════════════════════════════════════════════════════════
main_menu() {
  while true; do
    draw_header
    echo -e "  ${BOLD}${W}Главное меню${N}\n"
    echo -e "  ${C}[1]${N}  📊  Статус и мониторинг"
    echo -e "  ${C}[2]${N}  🔗  Ссылка для Telegram + QR-код"
    echo -e "  ${C}[3]${N}  🎨  Темы сайта-обманки"
    echo -e "  ${C}[4]${N}  ⚙️   Управление сервисами"
    echo -e "  ${C}[5]${N}  📋  Логи"
    echo -e "  ${C}[6]${N}  🔧  Настройки"
    echo -e "  ${C}[7]${N}  🔄  Обновление"
    echo ""
    echo -e "  ${R}[8]${N}  🗑️   Удалить / Переустановить"
    echo ""
    echo -e "  ${DIM}[0]${N}  🚪  Выход"
    echo ""
    read -rp "  Выберите [0-8]: " ch
    case "$ch" in
      1) menu_status ;;
      2) menu_link ;;
      3) menu_themes ;;
      4) menu_services ;;
      5) menu_logs ;;
      6) menu_settings ;;
      7) menu_update ;;
      8) menu_uninstall ;;
      0|q|Q) echo ""; exit 0 ;;
      *) echo -e "\n  ${R}Неверный выбор${N}"; sleep 1 ;;
    esac
  done
}

# ══════════════════════════════════════════════════════════════════════════
# 1. СТАТУС
# ══════════════════════════════════════════════════════════════════════════
menu_status() {
  while true; do
    load_cfg; get_stats; clear; echo ""
    top_b
    printf "${B}  ║${N}  ${BOLD}📊 %-53s${N}${B}║${N}\n" "Статус и мониторинг"
    sep
    for s in hipr-mtg nginx fail2ban; do
      printf "${B}  ║${N}  %-14s %-43b${B}║${N}\n" "$s" "$(svc_status $s)"
    done
    printf "${B}  ║${N}  %-14s %-43b${B}║${N}\n" "watchdog" \
      "$(svc_status hipr-watchdog.timer 2>/dev/null || echo '-')"
    sep
    local ip; ip=$(curl -s --max-time 4 ifconfig.me 2>/dev/null || echo "—")
    kv "🌍 Внешний IP:" "$ip"
    kv "🌐 Домен:" "${DOMAIN:-—}"
    kvc "📡 Активный DC:" "${ACTIVE_DC:-—}"
    kv "🎨 Тема сайта:" "$(active_theme)"
    sep
    kv "🔗 Активных:" "$STAT_ACTIVE сейчас / $STAT_TG_CONNS → Telegram"
    kv "📦 Трафик:" "$STAT_BYTES"
    kv "🛡️  Probing атак:" "${STAT_REPLAYS:-0}"
    local ce; ce=$(certbot certificates 2>/dev/null | grep -A3 "${DOMAIN:-_}" \
      | grep "Expiry" | awk '{print $3,$4}' | head -1)
    kv "🔒 Сертификат:" "${ce:-—}"
    local load; load=$(uptime | awk -F'load average:' '{print $2}' | awk '{print $1}' | tr -d ',')
    local mem; mem=$(free -m | awk '/Mem:/{printf "%.0f%% из %dMB", $3/$2*100, $2}')
    kv "💻 CPU load:" "$load"
    kv "💾 RAM:" "$mem"
    row ""; bot_b; echo ""
    echo -e "  ${C}[r]${N} Обновить  ${C}[t]${N} Проверить DC  ${C}[p]${N} Пинг прокси  ${R}[0]${N} Назад"
    echo ""
    read -rp "  " ch
    case "$ch" in
      r|R) continue ;;
      t|T) _check_all_dc ;;
      p|P) _ping_proxy ;;
      0|q) return ;;
    esac
  done
}

_check_all_dc() {
  clear; echo -e "\n  ${BOLD}📡 Проверка Telegram DC${N}\n"
  declare -A DC_NAMES=(
    ["149.154.175.50"]="DC1 Miami"
    ["149.154.167.51"]="DC2 Amsterdam"
    ["149.154.175.100"]="DC3 Miami"
    ["149.154.167.91"]="DC4 Amsterdam"
    ["91.108.56.130"]="DC5 Singapore"
  )
  load_cfg
  for ip in "149.154.175.50" "149.154.167.51" "149.154.175.100" "149.154.167.91" "91.108.56.130"; do
    local name="${DC_NAMES[$ip]}"
    local active_mark=""; [[ "$ip" == "${ACTIVE_DC:-}" ]] && active_mark="  ${Y}◀ активный${N}"
    local start; start=$(date +%s%N)
    if timeout 3 bash -c "echo '' > /dev/tcp/$ip/443" 2>/dev/null; then
      local end; end=$(date +%s%N)
      local ms=$(( (end - start) / 1000000 ))
      printf "  🟢  %-22s %-18s ${G}%dms${N}%b\n" "$name" "$ip" "$ms" "$active_mark"
    else
      printf "  🔴  %-22s %-18s ${R}недоступен${N}%b\n" "$name" "$ip" "$active_mark"
    fi
  done
  echo ""; pause
}

_ping_proxy() {
  load_cfg; clear; echo -e "\n  ${BOLD}🔗 Проверка прокси${N}\n"
  local http_code; http_code=$(curl -sk -o /dev/null -w "%{http_code}" \
    "https://${DOMAIN:-localhost}" --max-time 5 2>/dev/null || echo "000")
  if [[ "$http_code" == "200" || "$http_code" == "304" ]]; then
    echo -e "  🟢  Сайт-обманка: ${G}HTTP $http_code${N}"
  else
    echo -e "  🔴  Сайт-обманка: ${R}HTTP $http_code${N}"
  fi
  if ss -tlnp 2>/dev/null | grep -q '127.0.0.1:2398'; then
    echo -e "  🟢  mtg слушает: ${G}127.0.0.1:2398${N}"
  else
    echo -e "  🔴  mtg ${R}не слушает на 2398${N}"
  fi
  echo ""; pause
}

# ══════════════════════════════════════════════════════════════════════════
# 2. ССЫЛКА
# ══════════════════════════════════════════════════════════════════════════
menu_link() {
  load_cfg; clear; echo ""
  local tg="tg://proxy?server=${DOMAIN}&port=443&secret=${MTG_SECRET}"
  local ht="https://t.me/proxy?server=${DOMAIN}&port=443&secret=${MTG_SECRET}"
  top_b
  printf "${B}  ║${N}  ${BOLD}🔗 %-53s${N}${B}║${N}\n" "Ссылка для Telegram"
  sep; row ""
  echo -e "${B}  ║${N}  ${DIM}tg:// — открывает Telegram напрямую:${N}"
  echo -e "${B}  ║${N}  ${C}${tg}${N}"
  row ""
  echo -e "${B}  ║${N}  ${DIM}https:// — для браузера и ботов:${N}"
  echo -e "${B}  ║${N}  ${Y}${ht}${N}"
  row ""; sep
  kv "🔑 Секрет:" "${MTG_SECRET:0:28}..."
  kv "🌐 Домен:" "$DOMAIN"
  kv "🔌 Порт:" "443"
  kv "🛡️  Тип:" "FakeTLS (microsoft.com)"
  row ""; bot_b; echo ""
  if command -v qrencode &>/dev/null; then
    echo -e "  ${BOLD}📱 QR-код:${N}\n"
    qrencode -t ANSIUTF8 -l M "$ht" 2>/dev/null | sed 's/^/    /'
    echo ""
  fi
  echo -e "  ${C}[c]${N} 📋 Копировать ссылку  ${C}[s]${N} 📨 Отправить в бот  ${R}[0]${N} Назад"
  echo ""
  read -rp "  " ch
  case "$ch" in
    c|C)
      echo -n "$tg" | xclip -selection clipboard 2>/dev/null || \
        echo -n "$tg" | xsel --clipboard 2>/dev/null || \
        { echo -e "\n  ${Y}Ссылка:${N} $tg"; }
      echo -e "  ${G}✅ Скопировано${N}"; sleep 1 ;;
    s|S) _send_link_to_bot "$tg" ;;
  esac
}

_send_link_to_bot() {
  load_cfg
  local link="$1"
  if [[ -z "${BOT_TOKEN:-}" || -z "${BOT_CHAT_ID:-}" ]]; then
    echo -e "\n  ${Y}⚠️  Бот не настроен → hide → [6] Настройки → Telegram бот${N}"
    sleep 2; return
  fi
  local msg="🔗 <b>HIPR прокси</b>%0A%0A<code>${link}</code>%0A%0A🌐 Домен: ${DOMAIN}"
  if curl -s --max-time 10 \
    "https://api.telegram.org/bot${BOT_TOKEN}/sendMessage" \
    -d "chat_id=${BOT_CHAT_ID}&text=${msg}&parse_mode=HTML" > /dev/null 2>&1; then
    echo -e "\n  ${G}✅ Ссылка отправлена в бот${N}"
  else
    echo -e "\n  ${R}❌ Ошибка отправки — проверьте токен и chat_id${N}"
  fi
  sleep 2
}

# ══════════════════════════════════════════════════════════════════════════
# 3. ТЕМЫ
# ══════════════════════════════════════════════════════════════════════════
menu_themes() {
  while true; do
    clear; echo ""
    top_b
    printf "${B}  ║${N}  ${BOLD}🎨 %-53s${N}${B}║${N}\n" "Темы сайта-обманки"
    sep
    kv "✅ Активная:" "$(active_theme)"
    kv "📁 Папка:" "$THEMES_LOCAL"
    bot_b; echo ""
    echo -e "  ${C}[1]${N}  ✅  Выбрать из установленных"
    echo -e "  ${C}[2]${N}  ☁️   Скачать темы с GitHub"
    echo -e "  ${C}[3]${N}  📦  Добавить свою (папка или .zip)"
    echo -e "  ${C}[4]${N}  🌐  Открыть сайт в браузере"
    echo -e "  ${C}[5]${N}  🗑️   Удалить пользовательскую тему"
    echo ""; echo -e "  ${R}[0]${N}  ← Назад"; echo ""
    read -rp "  Выберите: " ch
    case "$ch" in
      1) themes_pick ;;
      2) themes_github ;;
      3) themes_add ;;
      4) themes_preview ;;
      5) themes_delete ;;
      0|q) return ;;
      *) echo -e "\n  ${R}Неверный выбор${N}"; sleep 1 ;;
    esac
  done
}

collect_themes() {
  THEME_DIRS=(); THEME_NAMES=(); THEME_DESCS=()
  for base in "$THEMES_LOCAL" "$THEMES_LOCAL/custom"; do
    [[ -d "$base" ]] || continue
    for dir in "$base"/*/; do
      [[ -f "$dir/index.html" ]] || continue
      [[ "$(basename "$dir")" == "custom" ]] && continue
      local jf="$dir/theme.json"
      local name="" desc=""
      if [[ -f "$jf" ]]; then
        name=$(python3 -c "import json; d=json.load(open('$jf')); print(d.get('name',''))" 2>/dev/null || true)
        desc=$(python3 -c "import json; d=json.load(open('$jf')); print(d.get('preview', d.get('description','')))" 2>/dev/null || true)
      fi
      name="${name:-$(basename "$dir")}"; desc="${desc:-—}"
      THEME_DIRS+=("${dir%/}"); THEME_NAMES+=("$name"); THEME_DESCS+=("$desc")
    done
  done
}

themes_pick() {
  collect_themes
  if [[ ${#THEME_DIRS[@]} -eq 0 ]]; then
    echo -e "\n  ${Y}⚠️  Нет тем — скачайте с GitHub (пункт 2)${N}"
    pause; return
  fi
  clear; echo ""
  top_b
  printf "${B}  ║${N}  ${BOLD}✅ %-53s${N}${B}║${N}\n" "Выбор темы"
  sep; row ""
  local active; active=$(active_theme)
  for i in "${!THEME_DIRS[@]}"; do
    local mark=""; [[ "${THEME_NAMES[$i]}" == "$active" ]] && mark=" ${G}◀ активна${N}"
    printf "${B}  ║${N}  ${C}[%d]${N} ${BOLD}%-30s${N}%-16b${B}║${N}\n" \
      "$((i+1))" "${THEME_NAMES[$i]}" "$mark"
    printf "${B}  ║${N}      ${DIM}%-52s${N}${B}║${N}\n" "${THEME_DESCS[$i]}"
    row ""
  done
  bot_b; echo ""; echo -e "  ${R}[0]${N}  ← Назад"; echo ""
  read -rp "  Номер темы: " ch
  [[ "$ch" == "0" || "$ch" == "q" ]] && return
  [[ ! "$ch" =~ ^[0-9]+$ ]] && { echo -e "\n  ${R}Неверный номер${N}"; sleep 1; return; }
  local idx=$((ch-1))
  if [[ $idx -ge 0 && $idx -lt ${#THEME_DIRS[@]} ]]; then
    themes_apply "${THEME_DIRS[$idx]}" "${THEME_NAMES[$idx]}"
  else
    echo -e "\n  ${R}Нет такой темы${N}"; sleep 1
  fi
}

themes_apply() {
  local src="$1" name="$2"
  echo ""; echo -e "  ${Y}🎨 Применяю тему: ${BOLD}$name${N}"
  if ls "$WEB_DIR"/*.html &>/dev/null 2>&1; then
    local bak="$THEMES_LOCAL/backup_$(date +%Y%m%d_%H%M%S)"
    mkdir -p "$bak"; cp -r "$WEB_DIR"/. "$bak/" 2>/dev/null
    echo -e "  ${DIM}💾 Бэкап: $bak${N}"
  fi
  rm -rf "${WEB_DIR:?}"/*
  cp -r "$src"/. "$WEB_DIR/"
  printf 'User-agent: *\nDisallow: /\n' > "$WEB_DIR/robots.txt"
  chown -R www-data:www-data "$WEB_DIR" 2>/dev/null || true
  echo "$name" > "$HIDE_DIR/config/active_theme"
  if nginx -t 2>/dev/null; then
    systemctl reload nginx
    echo -e "  ${G}✅ Тема «$name» активирована${N}"
  else
    echo -e "  ${R}❌ Ошибка nginx — откат${N}"
    [[ -n "${bak:-}" ]] && cp -r "${bak:-}"/. "$WEB_DIR/" 2>/dev/null
  fi
  pause
}

themes_github() {
  clear; echo -e "\n  ${BOLD}☁️  Темы на GitHub${N}\n"
  echo -e "  ${DIM}Загружаем список...${N}\n"
  if ! curl -sf --max-time 5 https://api.github.com > /dev/null 2>&1; then
    echo -e "  ${R}❌ GitHub недоступен${N}"; pause; return
  fi
  local api_json; api_json=$(curl -sf --max-time 10 "$THEMES_API" 2>/dev/null || echo "[]")
  local dirs; dirs=$(echo "$api_json" | python3 -c "
import sys,json
try:
  for i in json.load(sys.stdin):
    if i.get('type')=='dir' and i['name'] not in ['backup','custom']:
      print(i['name'])
except: pass" 2>/dev/null || echo "blog
freelancer
coming-soon")
  local arr=(); while IFS= read -r t; do [[ -n "$t" ]] && arr+=("$t"); done <<< "$dirs"
  for i in "${!arr[@]}"; do
    local t="${arr[$i]}"
    local inst=""; [[ -d "$THEMES_LOCAL/$t" ]] && inst="${G}[установлена]${N}"
    local desc; desc=$(curl -sf --max-time 5 "$THEMES_RAW/$t/theme.json" 2>/dev/null \
      | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('preview',d.get('description','')))" \
      2>/dev/null || echo "")
    printf "  ${C}[%d]${N} ${BOLD}%-22s${N} %-20b\n" "$((i+1))" "$t" "$inst"
    [[ -n "$desc" ]] && echo -e "      ${DIM}$desc${N}"
    echo ""
  done
  echo -e "  ${C}[a]${N}  📥 Скачать все"
  echo -e "  ${R}[0]${N}  ← Назад"; echo ""
  read -rp "  Выбор: " ch
  if [[ "$ch" == "a" || "$ch" == "A" ]]; then
    for t in "${arr[@]}"; do _dl_theme "$t"; done
  elif [[ "$ch" =~ ^[0-9]+$ ]]; then
    local idx=$((ch-1))
    [[ $idx -ge 0 && $idx -lt ${#arr[@]} ]] && _dl_theme "${arr[$idx]}"
  fi
  pause
}

_dl_theme() {
  local name="$1" dest="$THEMES_LOCAL/$name"
  echo -e "\n  ${Y}📥 Скачиваю: $name${N}"
  mkdir -p "$dest"
  local flist; flist=$(curl -sf --max-time 10 "$THEMES_API/$name" 2>/dev/null \
    | python3 -c "
import sys,json
try:
  for f in json.load(sys.stdin):
    if f.get('type')=='file': print(f['name'], f['download_url'])
except: pass" 2>/dev/null)
  if [[ -n "$flist" ]]; then
    while IFS=' ' read -r fname furl; do
      [[ -z "$fname" ]] && continue
      curl -sf --max-time 15 "$furl" -o "$dest/$fname" 2>/dev/null \
        && echo -e "    ${G}✓${N} $fname" || echo -e "    ${R}✗${N} $fname"
    done <<< "$flist"
  else
    for f in index.html theme.json about.html; do
      curl -sf --max-time 10 "$THEMES_RAW/$name/$f" -o "$dest/$f" 2>/dev/null \
        && echo -e "    ${G}✓${N} $f" || true
    done
  fi
  [[ -f "$dest/index.html" ]] \
    && echo -e "  ${G}✅ '$name' установлена${N}" \
    || { echo -e "  ${R}❌ index.html не найден${N}"; rm -rf "$dest"; }
}

themes_add() {
  clear; echo -e "\n  ${BOLD}📦 Добавить свою тему${N}\n"
  echo -e "  Укажите путь к папке с ${W}index.html${N} или к .zip архиву\n"
  read -rp "  Путь: " src; [[ -z "$src" ]] && return
  src="${src/#\~/$HOME}"
  if [[ -f "$src" && "$src" == *.zip ]]; then
    command -v unzip &>/dev/null || apt-get install -y -qq unzip 2>/dev/null
    local tmp; tmp=$(mktemp -d)
    unzip -q "$src" -d "$tmp"
    local idx_path; idx_path=$(find "$tmp" -name "index.html" | head -1)
    [[ -z "$idx_path" ]] && { echo -e "\n  ${R}❌ index.html не найден${N}"; rm -rf "$tmp"; sleep 2; return; }
    _install_theme "$(dirname "$idx_path")"
    rm -rf "$tmp"
  elif [[ -d "$src" ]]; then
    [[ ! -f "$src/index.html" ]] && { echo -e "\n  ${R}❌ Нет index.html${N}"; sleep 2; return; }
    _install_theme "$src"
  else
    echo -e "\n  ${R}❌ Путь не найден${N}"; sleep 2
  fi
}

_install_theme() {
  local src="$1" name=""
  [[ -f "$src/theme.json" ]] && \
    name=$(python3 -c "import json; d=json.load(open('$src/theme.json')); print(d.get('name',''))" 2>/dev/null || true)
  [[ -z "$name" ]] && { read -rp "  Название темы: " name; [[ -z "$name" ]] && return; }
  [[ ! -f "$src/theme.json" ]] && printf '{"name":"%s","description":"Пользовательская тема","author":"custom","version":"1.0","preview":"Пользовательская тема","pages":["index.html"]}' "$name" > "$src/theme.json"
  local safe; safe=$(echo "$name" | tr ' ' '-' | tr -cd '[:alnum:]-_' | tr '[:upper:]' '[:lower:]')
  local dest="$THEMES_LOCAL/custom/$safe"
  mkdir -p "$(dirname "$dest")"; cp -r "$src" "$dest"
  echo -e "\n  ${G}✅ Тема «$name» добавлена${N}\n"
  read -rp "  Применить сейчас? [Y/n]: " ap
  [[ "${ap,,}" != "n" ]] && themes_apply "$dest" "$name"
}

themes_preview() {
  load_cfg; echo ""
  [[ -n "${DOMAIN:-}" ]] \
    && echo -e "  🌐  ${C}https://$DOMAIN${N}\n  ${DIM}Это видит ТСПУ при проверке${N}" \
    || echo -e "  ${Y}⚠️  Домен не настроен${N}"
  echo ""; pause
}

themes_delete() {
  collect_themes
  local cdirs=(); local cnames=()
  for i in "${!THEME_DIRS[@]}"; do
    [[ "${THEME_DIRS[$i]}" == *"/custom/"* ]] && \
      { cdirs+=("${THEME_DIRS[$i]}"); cnames+=("${THEME_NAMES[$i]}"); }
  done
  if [[ ${#cdirs[@]} -eq 0 ]]; then
    echo -e "\n  ${Y}⚠️  Нет пользовательских тем${N}"; pause; return
  fi
  clear; echo -e "\n  ${BOLD}🗑️  Удалить тему${N}\n"
  for i in "${!cdirs[@]}"; do printf "  ${C}[%d]${N} %s\n" "$((i+1))" "${cnames[$i]}"; done
  echo ""; echo -e "  ${R}[0]${N} Назад"; echo ""
  read -rp "  Номер: " ch
  [[ "$ch" == "0" || "$ch" == "q" || -z "$ch" ]] && return
  [[ ! "$ch" =~ ^[0-9]+$ ]] && return
  local idx=$((ch-1))
  if [[ $idx -ge 0 && $idx -lt ${#cdirs[@]} ]]; then
    read -rp "  Удалить «${cnames[$idx]}»? [y/N]: " c
    [[ "${c,,}" == "y" ]] && { rm -rf "${cdirs[$idx]}"; echo -e "  ${G}✅ Удалена${N}"; sleep 1; }
  fi
}

